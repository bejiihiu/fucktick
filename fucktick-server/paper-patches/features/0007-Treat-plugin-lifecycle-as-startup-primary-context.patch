From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: bejiihiu <bejiihiu@icloud.com>
Date: Thu, 18 Jun 2026 05:00:29 +0500
Subject: [PATCH] Treat plugin lifecycle as startup primary context


diff --git a/src/main/java/org/bukkit/craftbukkit/CraftServer.java b/src/main/java/org/bukkit/craftbukkit/CraftServer.java
index 9583ff67f17f60883f0c0564eb95c700c85674b4..e61212c709e69acb9db7f469d1a05c915de8f4aa 100644
--- a/src/main/java/org/bukkit/craftbukkit/CraftServer.java
+++ b/src/main/java/org/bukkit/craftbukkit/CraftServer.java
@@ -2341,7 +2341,15 @@ public final class CraftServer implements Server {
 
     @Override
     public boolean isPrimaryThread() {
-        return ca.spottedleaf.moonrise.common.util.TickThread.isTickThread(); // Paper - rewrite chunk system
+        final boolean tickThread = ca.spottedleaf.moonrise.common.util.TickThread.isTickThread(); // Paper - rewrite chunk system
+        // FuckTick Start - поток жизненного цикла плагина как контекст запуска
+        if (!tickThread && "plugin-lifecycle".equals(io.papermc.paper.fucktick.plugin.FuckTickPluginContext.currentContextName())) {
+            // Некоторые Folia-совместимые плагины используют этот метод, чтобы не планировать
+            // стартовую работу на глобальный планировщик до первых тиков сервера.
+            return true;
+        }
+        // FuckTick End
+        return tickThread;
     }
 
     @Override
