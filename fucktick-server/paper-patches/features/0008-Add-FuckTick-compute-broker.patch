@@ -0,0 +1,23 @@
+package io.papermc.paper.fucktick.compute;
+
+public enum ComputePriority {
+    CRITICAL_SAVE(0),
+    HIGH_ENTITY_AI(1),
+    NORMAL_WORLD_COMPUTE(2),
+    LOW_DIAGNOSTICS(3),
+    BACKGROUND_WARMUP(4);
+
+    private final int rank;
+
+    ComputePriority(final int rank) {
+        this.rank = rank;
+    }
+
+    public int rank() {
+        return this.rank;
+    }
+
+    public boolean outranks(final ComputePriority other) {
+        return this.rank < other.rank;
+    }
+}
