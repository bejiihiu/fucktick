+    private static final class OwnerExecutor implements ComputeApplyExecutor, AutoCloseable {
+
+        private final BlockingQueue<Runnable> queue = new LinkedBlockingQueue<>();
+        private final CountDownLatch started = new CountDownLatch(1);
+        private final Thread thread;
+        private volatile boolean running = true;
+        private volatile Thread ownerThread;
+
+        private OwnerExecutor(final String name) throws InterruptedException {
+            this.thread = new Thread(this::run, name);
+            this.thread.start();
+            assertTrue(this.started.await(5L, TimeUnit.SECONDS));
+        }
+
+        @Override
+        public void execute(final Runnable runnable) {
+            this.queue.add(runnable);
+        }
+
+        @Override
+        public String ownerContext() {
+            return this.thread.getName();
+        }
+
+        @Override
+        public boolean isOwnerThread() {
+            return Thread.currentThread() == this.ownerThread;
+        }
+
+        @Override
+        public void close() throws InterruptedException {
+            this.running = false;
+            this.queue.add(() -> {
+            });
+            this.thread.join(TimeUnit.SECONDS.toMillis(5L));
+        }
+
+        private void run() {
+            this.ownerThread = Thread.currentThread();
+            this.started.countDown();
+            while (this.running) {
+                try {
+                    this.queue.take().run();
+                } catch (final InterruptedException ex) {
+                    Thread.currentThread().interrupt();
+                    return;
+                }
+            }
+        }
+    }
