+    @Test
+    void pathfindingTaskRunsOnComputeWorkerAndAppliesOnOwnerThread() throws Exception {
+        final FuckTickComputeBroker broker = broker(1, 16, 10_000L);
+        try (OwnerExecutor owner = new OwnerExecutor("entity-owner")) {
+            final AtomicReference<String> computeThread = new AtomicReference<>();
+            final AtomicReference<String> applyThread = new AtomicReference<>();
+            final TestSnapshot snapshot = broker.snapshot(
+                ComputeTaskType.PATHFINDING,
+                "entity-owner",
+                () -> true,
+                () -> new TestSnapshot(ComputeGeneration.of(1L), 41)
+            );
+
+            final ComputeTaskHandle<TestResult> handle = broker.submit(
+                ComputeTaskType.PATHFINDING,
+                ComputePriority.HIGH_ENTITY_AI,
+                new ComputeTaskOwner("world", null),
+                "pathfinding-test",
+                snapshot,
+                (input, token) -> {
+                    assertTrue(FuckTickComputeContext.isComputeWorker());
+                    assertEquals(ComputeTaskType.PATHFINDING, FuckTickComputeContext.currentTaskType());
+                    computeThread.set(Thread.currentThread().getName());
+                    return new TestResult(input.generation(), input.value() + 1);
+                },
+                owner,
+                (context, result) -> {
+                    assertTrue(owner.isOwnerThread());
+                    applyThread.set(Thread.currentThread().getName());
+                    assertEquals(42, result.value());
+                    return ComputeApplyDecision.APPLIED;
+                }
+            );
+
+            assertEquals(ComputeTaskState.APPLIED, handle.completion().get(5L, TimeUnit.SECONDS));
+            assertNotNull(computeThread.get());
+            assertTrue(computeThread.get().startsWith("FuckTick Compute Worker - "));
+            assertEquals("entity-owner", applyThread.get());
+            final ComputeTaskTypeSnapshot stats = broker.snapshot().taskTypes().stream()
+                .filter(type -> type.type() == ComputeTaskType.PATHFINDING)
+                .findFirst()
+                .orElseThrow();
+            assertEquals(1L, stats.submitted());
+            assertEquals(1L, stats.completed());
+            assertEquals(1L, stats.applied());
+        } finally {
+            broker.shutdown();
+        }
+    }
