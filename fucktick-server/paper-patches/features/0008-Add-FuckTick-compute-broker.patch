diff --git a/src/main/java/io/papermc/paper/fucktick/compute/ComputeWorkerPool.java b/src/main/java/io/papermc/paper/fucktick/compute/ComputeWorkerPool.java
new file mode 100644
index 0000000000000000000000000000000000000000..3b87581297fe90e5740702bbea39d4a349a8de00
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/compute/ComputeWorkerPool.java
@@ -0,0 +1,140 @@
+package io.papermc.paper.fucktick.compute;
+
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+import java.util.concurrent.ConcurrentHashMap;
+import java.util.concurrent.PriorityBlockingQueue;
+import java.util.concurrent.atomic.AtomicBoolean;
+import java.util.concurrent.atomic.AtomicInteger;
+
+final class ComputeWorkerPool {
+
+    private final FuckTickComputeBroker broker;
+    private final ComputeBudgetPolicy policy;
+    private final PriorityBlockingQueue<ComputeTask<?, ?>> queue = new PriorityBlockingQueue<>();
+    private final List<Thread> workers = new ArrayList<>();
+    private final ConcurrentHashMap<String, Long> workerTasks = new ConcurrentHashMap<>();
+    private final AtomicInteger queuedTasks = new AtomicInteger();
+    private final AtomicBoolean shutdown = new AtomicBoolean();
+
+    ComputeWorkerPool(final FuckTickComputeBroker broker, final ComputeBudgetPolicy policy) {
+        this.broker = broker;
+        this.policy = policy;
+        for (int i = 1; i <= policy.workerCount(); ++i) {
+            final Thread thread = new Thread(this::runWorker, "FuckTick Compute Worker - " + i);
+            thread.setDaemon(true);
+            this.workers.add(thread);
+        }
+    }
+
+    void start() {
+        for (final Thread worker : this.workers) {
+            worker.start();
+        }
+    }
+
+    boolean execute(final ComputeTask<?, ?> task) {
+        if (this.shutdown.get()) {
+            return false;
+        }
+        if (!this.reserveQueueSlot(task)) {
+            return false;
+        }
+        task.queuedNanos = System.nanoTime();
+        task.transition(ComputeTaskState.QUEUED);
+        this.queue.offer(task);
+        return true;
+    }
+
+    int queuedTasks() {
+        return this.queuedTasks.get();
+    }
+
+    List<ComputeWorkerSnapshot> snapshotWorkers() {
+        return this.workers.stream()
+            .map(worker -> new ComputeWorkerSnapshot(worker.getName(), worker.isAlive(), this.workerTasks.get(worker.getName())))
+            .toList();
+    }
+
+    void shutdown(final long waitMs) {
+        if (!this.shutdown.compareAndSet(false, true)) {
+            return;
+        }
+        for (final Thread worker : this.workers) {
+            worker.interrupt();
+        }
+        final List<ComputeTask<?, ?>> drained = new ArrayList<>();
+        this.queue.drainTo(drained);
+        this.queuedTasks.addAndGet(-drained.size());
+        for (final ComputeTask<?, ?> task : drained) {
+            task.cancellationToken.cancel("Compute broker shutdown");
+            this.broker.finishWithoutRunning(task, ComputeTaskState.CANCELLED, "");
+        }
+        final long deadline = System.currentTimeMillis() + waitMs;
+        for (final Thread worker : this.workers) {
+            final long remaining = Math.max(1L, deadline - System.currentTimeMillis());
+            try {
+                worker.join(remaining);
+            } catch (final InterruptedException ex) {
+                Thread.currentThread().interrupt();
+                return;
+            }
+        }
+    }
+
+    boolean isShutdown() {
+        return this.shutdown.get();
+    }
+
+    private boolean reserveQueueSlot(final ComputeTask<?, ?> task) {
+        for (;;) {
+            final int current = this.queuedTasks.get();
+            if (current < this.policy.maxQueuedComputeTasks()) {
+                if (this.queuedTasks.compareAndSet(current, current + 1)) {
+                    return true;
+                }
+                continue;
+            }
+            if (this.displaceLowerPriorityTask(task)) {
+                continue;
+            }
+            return false;
+        }
+    }
+
+    private boolean displaceLowerPriorityTask(final ComputeTask<?, ?> incoming) {
+        final ComputeTask<?, ?> candidate = this.queue.stream()
+            .filter(task -> incoming.priority.outranks(task.priority))
+            .max(Comparator.comparingInt(task -> task.priority.rank()))
+            .orElse(null);
+        if (candidate == null || !this.queue.remove(candidate)) {
+            return false;
+        }
+        this.queuedTasks.decrementAndGet();
+        candidate.cancellationToken.cancel("Displaced by higher priority compute task " + incoming.id);
+        this.broker.finishWithoutRunning(candidate, ComputeTaskState.REJECTED, "Displaced by higher priority compute task " + incoming.id);
+        return true;
+    }
+
+    private void runWorker() {
+        while (!this.shutdown.get()) {
+            final ComputeTask<?, ?> task;
+            try {
+                task = this.queue.take();
+            } catch (final InterruptedException ex) {
+                if (this.shutdown.get()) {
+                    return;
+                }
+                continue;
+            }
+            this.queuedTasks.decrementAndGet();
+            this.workerTasks.put(Thread.currentThread().getName(), task.id);
+            try {
+                this.broker.runTask(task);
+            } finally {
+                this.workerTasks.remove(Thread.currentThread().getName(), task.id);
+            }
+        }
+    }
+}
