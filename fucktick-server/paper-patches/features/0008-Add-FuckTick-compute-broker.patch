@@ -120,4 +144,132 @@ public final class FuckTickCommand extends Command {
         sender.sendMessage("GlobalRegionScheduler: owner-thread");
         sender.sendMessage("Unknown events: owner-only");
     }
+
+    // FuckTick Start - вывод состояния compute broker
+    private void sendCompute(final CommandSender sender, final String[] args) {
+        final ComputeBrokerSnapshot snapshot = FuckTickComputeBroker.instance().snapshot();
+        switch (args[1].toLowerCase(java.util.Locale.ROOT)) {
+            case "status" -> this.sendComputeStatus(sender, snapshot);
+            case "workers" -> this.sendComputeWorkers(sender, snapshot);
+            case "queue" -> this.sendComputeQueue(sender, snapshot);
+            case "tasks" -> this.sendComputeTasks(sender, snapshot);
+            case "task" -> {
+                if (args.length < 3) {
+                    sender.sendMessage("Usage: /fucktick compute task <id>");
+                    return;
+                }
+                try {
+                    this.sendComputeTask(sender, Long.parseLong(args[2]));
+                } catch (final NumberFormatException ex) {
+                    sender.sendMessage("Compute task id must be a number: " + args[2]);
+                }
+            }
+            default -> sender.sendMessage("Usage: " + this.usageMessage);
+        }
+    }
+
+    private void sendComputeStatus(final CommandSender sender, final ComputeBrokerSnapshot snapshot) {
+        final long completed = snapshot.taskTypes().stream().mapToLong(ComputeTaskTypeSnapshot::completed).sum();
+        final long applied = snapshot.taskTypes().stream().mapToLong(ComputeTaskTypeSnapshot::applied).sum();
+        final long stale = snapshot.taskTypes().stream().mapToLong(ComputeTaskTypeSnapshot::stale).sum();
+        final long rejected = snapshot.taskTypes().stream().mapToLong(ComputeTaskTypeSnapshot::rejected).sum();
+        sender.sendMessage("Compute Broker:");
+        sender.sendMessage("Workers: " + snapshot.workerCount());
+        sender.sendMessage("Queued: " + snapshot.queuedTasks());
+        sender.sendMessage("Running: " + snapshot.runningTasks());
+        sender.sendMessage("Completed: " + completed);
+        sender.sendMessage("Applied: " + applied);
+        sender.sendMessage("Stale: " + stale);
+        sender.sendMessage("Rejected: " + rejected);
+        sender.sendMessage("Shutdown: " + snapshot.shutdown());
+        sender.sendMessage("Top task types:");
+        snapshot.taskTypes().stream()
+            .filter(type -> type.submitted() > 0L || type.rejected() > 0L)
+            .sorted(Comparator.comparingLong(ComputeTaskTypeSnapshot::submitted).reversed())
+            .limit(8L)
+            .forEach(type -> sender.sendMessage(type.type()
+                + " queued=" + type.queued()
+                + " running=" + type.running()
+                + " avgCompute=" + ONE_DECIMAL.get().format(type.averageComputeTimeMs()) + "ms"
+                + " stale=" + type.stale()
+                + " rejected=" + type.rejected()));
+    }
+
+    private void sendComputeWorkers(final CommandSender sender, final ComputeBrokerSnapshot snapshot) {
+        for (final ComputeWorkerSnapshot worker : snapshot.workers()) {
+            sender.sendMessage(worker.name() + " alive=" + worker.alive() + " task=" + (worker.taskId() == null ? "-" : worker.taskId()));
+        }
+    }
+
+    private void sendComputeQueue(final CommandSender sender, final ComputeBrokerSnapshot snapshot) {
+        final List<ComputeTaskSnapshot> queued = snapshot.tasks().stream()
+            .filter(task -> task.state() == ComputeTaskState.QUEUED || task.state() == ComputeTaskState.SNAPSHOTTED || task.state() == ComputeTaskState.SUBMITTED)
+            .sorted(Comparator.comparing(ComputeTaskSnapshot::priority).thenComparingLong(ComputeTaskSnapshot::id))
+            .limit(20L)
+            .toList();
+        if (queued.isEmpty()) {
+            sender.sendMessage("Compute queue is empty.");
+            return;
+        }
+        for (final ComputeTaskSnapshot task : queued) {
+            sender.sendMessage(this.formatComputeTaskLine(task));
+        }
+    }
+
+    private void sendComputeTasks(final CommandSender sender, final ComputeBrokerSnapshot snapshot) {
+        final List<ComputeTaskSnapshot> tasks = snapshot.tasks().stream().limit(20L).toList();
+        if (tasks.isEmpty()) {
+            sender.sendMessage("No compute tasks tracked.");
+            return;
+        }
+        for (final ComputeTaskSnapshot task : tasks) {
+            sender.sendMessage(this.formatComputeTaskLine(task));
+        }
+    }
+
+    private void sendComputeTask(final CommandSender sender, final long taskId) {
+        final ComputeTaskSnapshot task = FuckTickComputeBroker.instance().taskSnapshot(taskId);
+        if (task == null) {
+            sender.sendMessage("Unknown compute task: " + taskId);
+            return;
+        }
+        sender.sendMessage("Task: " + task.id());
+        sender.sendMessage("Type: " + task.type());
+        sender.sendMessage("Priority: " + task.priority());
+        sender.sendMessage("State: " + task.state());
+        sender.sendMessage("Owner: " + task.owner().displayName());
+        sender.sendMessage("Generation: " + task.generation().value());
+        sender.sendMessage("Description: " + task.description());
+        sender.sendMessage("Worker thread: " + blankDash(task.workerThread()));
+        sender.sendMessage("Apply thread: " + blankDash(task.applyThread()));
+        sender.sendMessage("Queue time: " + millisOrDash(task.queueTimeMs()));
+        sender.sendMessage("Compute time: " + millisOrDash(task.computeTimeMs()));
+        sender.sendMessage("Apply delay: " + millisOrDash(task.applyDelayMs()));
+        if (task.cancelled()) {
+            sender.sendMessage("Cancellation: " + blankDash(task.cancellationReason()));
+        }
+        if (!task.failureMessage().isBlank()) {
+            sender.sendMessage("Failure: " + task.failureMessage());
+        }
+    }
+
+    private String formatComputeTaskLine(final ComputeTaskSnapshot task) {
+        return "#" + task.id()
+            + " " + task.type()
+            + " state=" + task.state()
+            + " priority=" + task.priority()
+            + " owner=" + task.owner().displayName()
+            + " queue=" + millisOrDash(task.queueTimeMs())
+            + " compute=" + millisOrDash(task.computeTimeMs())
+            + " description=\"" + task.description() + "\"";
+    }
+
+    private static String millisOrDash(final long millis) {
+        return millis < 0L ? "-" : millis + "ms";
+    }
+
+    private static String blankDash(final String value) {
+        return value == null || value.isBlank() ? "-" : value;
+    }
+    // FuckTick End
 }
