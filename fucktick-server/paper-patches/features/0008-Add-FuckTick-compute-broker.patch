diff --git a/src/main/java/io/papermc/paper/fucktick/compute/ComputeBudgetPolicy.java b/src/main/java/io/papermc/paper/fucktick/compute/ComputeBudgetPolicy.java
new file mode 100644
index 0000000000000000000000000000000000000000..31ccd481a3f30c54854318cc164dccb5ff591973
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/compute/ComputeBudgetPolicy.java
@@ -0,0 +1,76 @@
+package io.papermc.paper.fucktick.compute;
+
+public record ComputeBudgetPolicy(
+    int workerCount,
+    int maxQueuedComputeTasks,
+    int maxQueuedComputeTasksPerWorld,
+    int maxQueuedComputeTasksPerPlugin,
+    int maxPathfindingTasksPerTick,
+    int maxExplosionPrecomputeTasksPerTick,
+    int maxChunkSerializationTasks,
+    long maxComputeTimeMs,
+    long maxApplyDelayMs,
+    long shutdownWaitMs,
+    int maxTrackedTasks
+) {
+
+    public ComputeBudgetPolicy {
+        if (workerCount < 1) {
+            throw new IllegalArgumentException("workerCount must be positive");
+        }
+        if (maxQueuedComputeTasks < 1 || maxQueuedComputeTasksPerWorld < 1 || maxQueuedComputeTasksPerPlugin < 1) {
+            throw new IllegalArgumentException("queue limits must be positive");
+        }
+        if (maxPathfindingTasksPerTick < 1 || maxExplosionPrecomputeTasksPerTick < 1 || maxChunkSerializationTasks < 1) {
+            throw new IllegalArgumentException("task type limits must be positive");
+        }
+        if (maxComputeTimeMs < 1L || maxApplyDelayMs < 1L || shutdownWaitMs < 1L) {
+            throw new IllegalArgumentException("time limits must be positive");
+        }
+        if (maxTrackedTasks < 32) {
+            throw new IllegalArgumentException("maxTrackedTasks must be at least 32");
+        }
+    }
+
+    public static ComputeBudgetPolicy fromSystemProperties() {
+        final int processors = Math.max(1, Runtime.getRuntime().availableProcessors());
+        final int defaultWorkers = Math.max(1, Math.min(8, processors / 2));
+        return new ComputeBudgetPolicy(
+            readInt("fucktick.compute.workers", defaultWorkers),
+            readInt("fucktick.compute.maxQueuedTasks", 5_000),
+            readInt("fucktick.compute.maxQueuedTasksPerWorld", 2_000),
+            readInt("fucktick.compute.maxQueuedTasksPerPlugin", 1_000),
+            readInt("fucktick.compute.maxPathfindingTasksPerTick", 256),
+            readInt("fucktick.compute.maxExplosionPrecomputeTasksPerTick", 64),
+            readInt("fucktick.compute.maxChunkSerializationTasks", 256),
+            readLong("fucktick.compute.maxComputeTimeMs", 5_000L),
+            readLong("fucktick.compute.maxApplyDelayMs", 10_000L),
+            readLong("fucktick.compute.shutdownWaitMs", 10_000L),
+            readInt("fucktick.compute.maxTrackedTasks", 2_048)
+        );
+    }
+
+    private static int readInt(final String property, final int fallback) {
+        final String value = System.getProperty(property);
+        if (value == null || value.isBlank()) {
+            return fallback;
+        }
+        try {
+            return Integer.parseInt(value);
+        } catch (final NumberFormatException ex) {
+            return fallback;
+        }
+    }
+
+    private static long readLong(final String property, final long fallback) {
+        final String value = System.getProperty(property);
+        if (value == null || value.isBlank()) {
+            return fallback;
+        }
+        try {
+            return Long.parseLong(value);
+        } catch (final NumberFormatException ex) {
+            return fallback;
+        }
+    }
+}
diff --git a/src/main/java/io/papermc/paper/fucktick/compute/ComputeCancellationToken.java b/src/main/java/io/papermc/paper/fucktick/compute/ComputeCancellationToken.java
