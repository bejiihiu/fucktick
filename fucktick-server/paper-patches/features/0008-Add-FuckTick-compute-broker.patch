@@ -0,0 +1,55 @@
+package io.papermc.paper.fucktick.compute;
+
+public final class FuckTickComputeContext {
+
+    private static final ThreadLocal<Context> CURRENT = new ThreadLocal<>();
+
+    private FuckTickComputeContext() {
+    }
+
+    static Scope enter(final long taskId, final ComputeTaskType type, final ComputePriority priority, final String description) {
+        final Context previous = CURRENT.get();
+        CURRENT.set(new Context(taskId, type, priority, description));
+        return () -> {
+            if (previous == null) {
+                CURRENT.remove();
+            } else {
+                CURRENT.set(previous);
+            }
+        };
+    }
+
+    public static boolean isComputeWorker() {
+        return CURRENT.get() != null;
+    }
+
+    public static long currentTaskId() {
+        final Context context = CURRENT.get();
+        return context == null ? -1L : context.taskId;
+    }
+
+    public static ComputeTaskType currentTaskType() {
+        final Context context = CURRENT.get();
+        return context == null ? null : context.type;
+    }
+
+    public static ComputePriority currentPriority() {
+        final Context context = CURRENT.get();
+        return context == null ? null : context.priority;
+    }
+
+    public static String currentDescription() {
+        final Context context = CURRENT.get();
+        return context == null ? "" : context.description;
+    }
+
+    @FunctionalInterface
+    interface Scope extends AutoCloseable {
+
+        @Override
+        void close();
+    }
+
+    private record Context(long taskId, ComputeTaskType type, ComputePriority priority, String description) {
+    }
+}
diff --git a/src/main/java/io/papermc/paper/fucktick/compute/FuckTickComputeThreadChecks.java b/src/main/java/io/papermc/paper/fucktick/compute/FuckTickComputeThreadChecks.java
new file mode 100644
index 0000000000000000000000000000000000000000..dcd0653589146a99d96a64ae5f98befb03e46862
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/compute/FuckTickComputeThreadChecks.java
@@ -0,0 +1,85 @@
+package io.papermc.paper.fucktick.compute;
+
+import java.lang.reflect.Field;
+import java.lang.reflect.Modifier;
+import java.util.Collection;
+import java.util.Map;
+import java.util.Optional;
+
+public final class FuckTickComputeThreadChecks {
+
+    private static final String[] FORBIDDEN_LIVE_PREFIXES = {
+        "org.bukkit.World",
+        "org.bukkit.Chunk",
+        "org.bukkit.block.Block",
+        "org.bukkit.block.BlockState",
+        "org.bukkit.entity.Entity",
+        "org.bukkit.entity.Player",
+        "net.minecraft.world.level.Level",
+        "net.minecraft.world.level.chunk.ChunkAccess",
+        "net.minecraft.world.entity.Entity",
+        "net.minecraft.server.level.ServerLevel",
+        "net.minecraft.server.level.ServerPlayer"
+    };
+
+    private FuckTickComputeThreadChecks() {
+    }
+
+    public static void requireNotOwnerAccess() {
+        requireNotOwnerAccess("live world state");
+    }
+
+    public static void requireNotOwnerAccess(final String attemptedAccess) {
+        if (!FuckTickComputeContext.isComputeWorker()) {
+            return;
+        }
+        final ComputeTaskType type = FuckTickComputeContext.currentTaskType();
+        throw new IllegalStateException("Compute task " + type + " attempted to access " + attemptedAccess + " from a compute worker. Use owner-thread snapshot data and schedule validated apply instead.");
+    }
+
+    public static void requireImmutableSnapshot(final ComputeSnapshot snapshot) {
+        if (snapshot == null) {
+            throw new IllegalArgumentException("Compute snapshot cannot be null.");
+        }
+        inspectSnapshotClass(snapshot.getClass());
+    }
+
+    private static void inspectSnapshotClass(final Class<?> snapshotClass) {
+        for (final Field field : snapshotClass.getDeclaredFields()) {
+            if (Modifier.isStatic(field.getModifiers())) {
+                continue;
+            }
+            final Class<?> type = field.getType();
+            if (isForbiddenLiveType(type)) {
+                throw new IllegalArgumentException("Compute snapshot " + snapshotClass.getName() + " contains live owner-bound field " + field.getName() + " of type " + type.getName() + ".");
+            }
+            if (!isKnownImmutableContainer(type) && !Modifier.isFinal(field.getModifiers()) && !snapshotClass.isRecord()) {
+                throw new IllegalArgumentException("Compute snapshot " + snapshotClass.getName() + " must keep field " + field.getName() + " immutable.");
+            }
+        }
+    }
+
+    private static boolean isKnownImmutableContainer(final Class<?> type) {
+        return type.isPrimitive()
+            || type.isEnum()
+            || type == String.class
+            || Number.class.isAssignableFrom(type)
+            || type == Boolean.class
+            || type == Character.class
+            || type == java.util.UUID.class
+            || type == ComputeGeneration.class
+            || Collection.class.isAssignableFrom(type)
+            || Map.class.isAssignableFrom(type)
+            || Optional.class.isAssignableFrom(type);
+    }
+
+    private static boolean isForbiddenLiveType(final Class<?> type) {
+        final String name = type.getName();
+        for (final String forbidden : FORBIDDEN_LIVE_PREFIXES) {
+            if (name.equals(forbidden) || name.startsWith(forbidden + "$")) {
+                return true;
+            }
+        }
+        return false;
+    }
+}
