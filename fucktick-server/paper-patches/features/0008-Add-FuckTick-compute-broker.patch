+            final CountDownLatch release = new CountDownLatch(1);
+            final ComputeTaskHandle<TestResult> blocker = broker.submit(
+                ComputeTaskType.GENERIC,
+                ComputePriority.NORMAL_WORLD_COMPUTE,
+                ComputeTaskOwner.SERVER,
