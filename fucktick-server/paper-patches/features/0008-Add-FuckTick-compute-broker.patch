index 0000000000000000000000000000000000000000..604da0445718009f2a19161d9518d0ccfcdbbbad
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/compute/ComputeTask.java
@@ -0,0 +1,102 @@
+package io.papermc.paper.fucktick.compute;
+
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.atomic.AtomicReference;
+
+final class ComputeTask<S extends ComputeSnapshot, R extends ComputeResult> implements Comparable<ComputeTask<?, ?>> {
+
+    final long id;
+    final long sequence;
+    final ComputeTaskType type;
+    final ComputePriority priority;
+    final ComputeTaskOwner owner;
+    final ComputeGeneration generation;
+    final String description;
+    final S snapshot;
+    final ComputeWorkload<S, R> workload;
+    final ComputeApplyExecutor applyExecutor;
+    final ComputeApplyHandle<R> applyHandle;
+    final ComputeCancellationToken cancellationToken = new ComputeCancellationToken();
+    final CompletableFuture<ComputeTaskState> completion = new CompletableFuture<>();
+    final long submittedNanos = System.nanoTime();
+    final AtomicReference<ComputeTaskState> state = new AtomicReference<>(ComputeTaskState.SUBMITTED);
+    volatile long queuedNanos = -1L;
+    volatile long runningNanos = -1L;
+    volatile long computeFinishedNanos = -1L;
+    volatile long applyScheduledNanos = -1L;
+    volatile long terminalNanos = -1L;
+    volatile String workerThread = "";
+    volatile String applyThread = "";
+    volatile String failureMessage = "";
+
+    ComputeTask(
+        final long id,
+        final long sequence,
+        final ComputeTaskType type,
+        final ComputePriority priority,
+        final ComputeTaskOwner owner,
+        final String description,
+        final S snapshot,
+        final ComputeWorkload<S, R> workload,
+        final ComputeApplyExecutor applyExecutor,
+        final ComputeApplyHandle<R> applyHandle
+    ) {
+        this.id = id;
+        this.sequence = sequence;
+        this.type = type;
+        this.priority = priority;
+        this.owner = owner;
+        this.description = description;
+        this.snapshot = snapshot;
+        this.generation = snapshot.generation();
+        this.workload = workload;
+        this.applyExecutor = applyExecutor;
+        this.applyHandle = applyHandle;
+    }
+
+    void transition(final ComputeTaskState state) {
+        this.state.set(state);
+        if (state.isTerminal()) {
+            this.terminalNanos = System.nanoTime();
+            this.completion.complete(state);
+        }
+    }
+
+    ComputeTaskSnapshot snapshot() {
+        final long now = System.nanoTime();
+        return new ComputeTaskSnapshot(
+            this.id,
+            this.type,
+            this.priority,
+            this.state.get(),
+            this.owner,
+            this.generation,
+            this.description,
+            this.workerThread,
+            this.applyThread,
+            elapsedMillis(this.queuedNanos, this.runningNanos > 0L ? this.runningNanos : now),
+            elapsedMillis(this.runningNanos, this.computeFinishedNanos > 0L ? this.computeFinishedNanos : now),
+            elapsedMillis(this.computeFinishedNanos, this.applyScheduledNanos > 0L ? this.applyScheduledNanos : now),
+            this.cancellationToken.isCancelled(),
+            this.cancellationToken.reason(),
+            this.failureMessage
+        );
+    }
+
+    boolean isTerminal() {
+        return this.state.get().isTerminal();
+    }
+
+    @Override
+    public int compareTo(final ComputeTask<?, ?> other) {
+        final int priorityCompare = Integer.compare(this.priority.rank(), other.priority.rank());
+        return priorityCompare != 0 ? priorityCompare : Long.compare(this.sequence, other.sequence);
+    }
+
+    private static long elapsedMillis(final long startNanos, final long endNanos) {
+        if (startNanos <= 0L || endNanos <= 0L || endNanos < startNanos) {
+            return -1L;
+        }
+        return (endNanos - startNanos) / 1_000_000L;
+    }
+}
