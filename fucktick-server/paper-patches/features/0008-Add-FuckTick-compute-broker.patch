diff --git a/src/main/java/io/papermc/paper/fucktick/compute/FuckTickComputeBroker.java b/src/main/java/io/papermc/paper/fucktick/compute/FuckTickComputeBroker.java
new file mode 100644
index 0000000000000000000000000000000000000000..47ba3769dfc22be3be0f5759c43d96ec17872d7d
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/compute/FuckTickComputeBroker.java
@@ -0,0 +1,413 @@
+package io.papermc.paper.fucktick.compute;
+
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.EnumMap;
+import java.util.List;
+import java.util.Objects;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ConcurrentHashMap;
+import java.util.concurrent.ConcurrentLinkedDeque;
+import java.util.concurrent.atomic.AtomicInteger;
+import java.util.concurrent.atomic.AtomicLong;
+import java.util.concurrent.atomic.AtomicReference;
+import java.util.function.BooleanSupplier;
+import java.util.function.Supplier;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+public final class FuckTickComputeBroker {
+
+    private static final Logger LOGGER = LoggerFactory.getLogger(FuckTickComputeBroker.class);
+    private static final AtomicReference<FuckTickComputeBroker> INSTANCE = new AtomicReference<>();
+
+    private final ComputeBudgetPolicy policy;
+    private final ComputeDiagnostics diagnostics = new ComputeDiagnostics();
+    private final ComputeWorkerPool workerPool;
+    private final AtomicLong taskIds = new AtomicLong();
+    private final AtomicLong sequences = new AtomicLong();
+    private final ConcurrentHashMap<Long, ComputeTask<?, ?>> tasks = new ConcurrentHashMap<>();
+    private final ConcurrentLinkedDeque<Long> taskOrder = new ConcurrentLinkedDeque<>();
+    private final AtomicInteger trackedTasks = new AtomicInteger();
+    private final EnumMap<ComputeTaskType, AtomicInteger> inFlightByType = new EnumMap<>(ComputeTaskType.class);
+    private final ConcurrentHashMap<String, AtomicInteger> inFlightByWorld = new ConcurrentHashMap<>();
+    private final ConcurrentHashMap<String, AtomicInteger> inFlightByPlugin = new ConcurrentHashMap<>();
+
+    public static FuckTickComputeBroker instance() {
+        final FuckTickComputeBroker current = INSTANCE.get();
+        if (current != null) {
+            return current;
+        }
+        final FuckTickComputeBroker created = new FuckTickComputeBroker(ComputeBudgetPolicy.fromSystemProperties());
+        if (INSTANCE.compareAndSet(null, created)) {
+            return created;
+        }
+        created.shutdown();
+        return INSTANCE.get();
+    }
+
+    public static void shutdownIfInitialized() {
+        final FuckTickComputeBroker current = INSTANCE.get();
+        if (current != null) {
+            current.shutdown();
+        }
+    }
+
+    static FuckTickComputeBroker createForTesting(final ComputeBudgetPolicy policy) {
+        return new FuckTickComputeBroker(policy);
+    }
+
+    private FuckTickComputeBroker(final ComputeBudgetPolicy policy) {
+        this.policy = policy;
+        for (final ComputeTaskType type : ComputeTaskType.values()) {
+            this.inFlightByType.put(type, new AtomicInteger());
+        }
+        this.workerPool = new ComputeWorkerPool(this, policy);
+        this.workerPool.start();
+    }
+
+    public <S extends ComputeSnapshot> S snapshot(
+        final ComputeTaskType type,
+        final String ownerContext,
+        final BooleanSupplier ownerThreadCheck,
+        final Supplier<S> snapshotSupplier
+    ) {
+        Objects.requireNonNull(type, "type");
+        Objects.requireNonNull(ownerThreadCheck, "ownerThreadCheck");
+        Objects.requireNonNull(snapshotSupplier, "snapshotSupplier");
+        if (FuckTickComputeContext.isComputeWorker()) {
+            throw new IllegalStateException("Compute task " + FuckTickComputeContext.currentTaskType() + " attempted to create a live snapshot from a compute worker.");
+        }
+        if (!ownerThreadCheck.getAsBoolean()) {
+            throw new IllegalStateException("Compute snapshot for " + type + " was requested outside owner context " + ownerContext + ".");
+        }
+        final S snapshot = Objects.requireNonNull(snapshotSupplier.get(), "snapshot");
+        FuckTickComputeThreadChecks.requireImmutableSnapshot(snapshot);
+        return snapshot;
+    }
+
+    public <S extends ComputeSnapshot, R extends ComputeResult> ComputeTaskHandle<R> submit(
+        final ComputeTaskType type,
+        final ComputePriority priority,
+        final ComputeTaskOwner owner,
+        final String description,
+        final S snapshot,
+        final ComputeWorkload<S, R> workload,
+        final ComputeApplyExecutor applyExecutor,
+        final ComputeApplyHandle<R> applyHandle
+    ) {
+        Objects.requireNonNull(type, "type");
+        Objects.requireNonNull(priority, "priority");
+        Objects.requireNonNull(owner, "owner");
+        Objects.requireNonNull(snapshot, "snapshot");
+        Objects.requireNonNull(workload, "workload");
+        Objects.requireNonNull(applyExecutor, "applyExecutor");
+        Objects.requireNonNull(applyHandle, "applyHandle");
+        this.diagnostics.submitted(type);
+        FuckTickComputeThreadChecks.requireImmutableSnapshot(snapshot);
+
+        final ComputeTask<S, R> task = new ComputeTask<>(
+            this.taskIds.incrementAndGet(),
+            this.sequences.incrementAndGet(),
+            type,
+            priority,
+            owner,
+            description == null || description.isBlank() ? type.name() : description,
+            snapshot,
+            workload,
+            applyExecutor,
+            applyHandle
+        );
+        this.track(task);
+        task.transition(ComputeTaskState.SNAPSHOTTED);
+
+        if (!this.reserveBudget(task)) {
+            this.rejectNewTask(task, "Compute task rejected by budget. type=" + type + " owner=" + owner.displayName());
+            return this.handle(task);
+        }
+        if (!this.workerPool.execute(task)) {
+            this.releaseBudget(task);
+            this.rejectNewTask(task, "Compute task rejected. queued=" + this.workerPool.queuedTasks() + " limit=" + this.policy.maxQueuedComputeTasks());
+            return this.handle(task);
+        }
+        this.diagnostics.queued(type);
+        return this.handle(task);
+    }
+
+    public ComputeBrokerSnapshot snapshot() {
+        final List<ComputeTaskSnapshot> taskSnapshots = this.tasks.values().stream()
+            .map(ComputeTask::snapshot)
+            .sorted(Comparator.comparingLong(ComputeTaskSnapshot::id).reversed())
+            .toList();
+        final int running = (int)taskSnapshots.stream().filter(task -> task.state() == ComputeTaskState.RUNNING).count();
+        return new ComputeBrokerSnapshot(
+            this.workerPool.isShutdown(),
+            this.policy.workerCount(),
+            this.workerPool.queuedTasks(),
+            running,
+            this.workerPool.snapshotWorkers(),
+            this.diagnostics.snapshot(),
+            taskSnapshots
+        );
+    }
+
+    public ComputeTaskSnapshot taskSnapshot(final long taskId) {
+        final ComputeTask<?, ?> task = this.tasks.get(taskId);
+        return task == null ? null : task.snapshot();
+    }
+
+    public void shutdown() {
+        this.workerPool.shutdown(this.policy.shutdownWaitMs());
+    }
+
+    <S extends ComputeSnapshot, R extends ComputeResult> void runTask(final ComputeTask<S, R> task) {
+        if (task.cancellationToken.isCancelled()) {
+            this.finishTask(task, ComputeTaskState.CANCELLED, "");
+            return;
+        }
+        task.workerThread = Thread.currentThread().getName();
+        task.runningNanos = System.nanoTime();
+        task.transition(ComputeTaskState.RUNNING);
+        this.diagnostics.running(task.type);
+        final R result;
+        try (FuckTickComputeContext.Scope ignored = FuckTickComputeContext.enter(task.id, task.type, task.priority, task.description)) {
+            result = Objects.requireNonNull(task.workload.compute(task.snapshot, task.cancellationToken), "compute result");
+        } catch (final ComputeTaskCancelledException ex) {
+            task.cancellationToken.cancel(ex.getMessage());
+            this.finishRunningTask(task, ComputeTaskState.CANCELLED, "");
+            return;
+        } catch (final Throwable throwable) {
+            if (this.workerPool.isShutdown() && throwable instanceof InterruptedException) {
+                Thread.currentThread().interrupt();
+                task.cancellationToken.cancel("Compute broker shutdown");
+                this.finishRunningTask(task, ComputeTaskState.CANCELLED, "");
+                return;
+            }
+            this.finishRunningTask(task, ComputeTaskState.FAILED, throwable.toString());
+            LOGGER.error("FuckTick compute task failed. id={} type={} description={}", task.id, task.type, task.description, throwable);
+            return;
+        }
+        task.computeFinishedNanos = System.nanoTime();
+        final long computeNanos = task.computeFinishedNanos - task.runningNanos;
+        this.diagnostics.completed(task.type, task.runningNanos - task.queuedNanos, computeNanos);
+        this.diagnostics.stoppedRunning(task.type);
+        if (computeNanos > this.policy.maxComputeTimeMs() * 1_000_000L) {
+            LOGGER.warn("FuckTick compute task exceeded compute budget. id={} type={} computeMs={} budgetMs={}", task.id, task.type, computeNanos / 1_000_000L, this.policy.maxComputeTimeMs());
+        }
+
+        if (task.cancellationToken.isCancelled()) {
+            this.finishTask(task, ComputeTaskState.CANCELLED, "");
+            return;
+        }
+        if (!task.generation.equals(result.generation()) || this.isPastApplyDeadline(task)) {
+            this.finishTask(task, ComputeTaskState.STALE, "");
+            return;
+        }
+        task.transition(ComputeTaskState.COMPLETED);
+        task.applyScheduledNanos = System.nanoTime();
+        task.transition(ComputeTaskState.APPLY_SCHEDULED);
+        try {
+            task.applyExecutor.execute(() -> this.runApply(task, result));
+        } catch (final Throwable throwable) {
+            this.finishTask(task, ComputeTaskState.FAILED, throwable.toString());
+            LOGGER.error("FuckTick compute apply scheduling failed. id={} type={} description={}", task.id, task.type, task.description, throwable);
+        }
+    }
+
+    void finishWithoutRunning(final ComputeTask<?, ?> task, final ComputeTaskState state, final String failureMessage) {
+        this.finishTask(task, state, failureMessage);
+    }
+
+    private <R extends ComputeResult> void runApply(final ComputeTask<?, R> task, final R result) {
+        task.applyThread = Thread.currentThread().getName();
+        final long applyStartNanos = System.nanoTime();
+        if (task.cancellationToken.isCancelled()) {
+            this.finishTask(task, ComputeTaskState.CANCELLED, "");
+            return;
+        }
+        if (!task.generation.equals(result.generation()) || this.isPastApplyDeadline(task)) {
+            this.finishTask(task, ComputeTaskState.STALE, "");
+            return;
+        }
+        try {
+            if (!task.applyExecutor.isOwnerThread()) {
+                throw new IllegalStateException("Compute task " + task.id + " apply did not run on owner context " + task.applyExecutor.ownerContext() + ".");
+            }
+            final ComputeApplyContext context = new ComputeApplyContext(task.id, task.type, task.owner, task.generation, task.cancellationToken);
+            final ComputeApplyDecision decision = Objects.requireNonNull(task.applyHandle.apply(context, result), "apply decision");
+            switch (decision) {
+                case APPLIED -> {
+                    this.diagnostics.applied(task.type, applyStartNanos - task.computeFinishedNanos);
+                    this.finishTask(task, ComputeTaskState.APPLIED, "");
+                }
+                case STALE -> this.finishTask(task, ComputeTaskState.STALE, "");
+                case CANCELLED -> {
+                    task.cancellationToken.cancel("Apply returned cancellation");
+                    this.finishTask(task, ComputeTaskState.CANCELLED, "");
+                }
+            }
+        } catch (final Throwable throwable) {
+            this.finishTask(task, ComputeTaskState.FAILED, throwable.toString());
+            LOGGER.error("FuckTick compute apply failed. id={} type={} description={}", task.id, task.type, task.description, throwable);
+        }
+    }
+
+    private void finishRunningTask(final ComputeTask<?, ?> task, final ComputeTaskState state, final String failureMessage) {
+        task.computeFinishedNanos = System.nanoTime();
+        this.diagnostics.stoppedRunning(task.type);
+        this.finishTask(task, state, failureMessage);
+    }
+
+    private void finishTask(final ComputeTask<?, ?> task, final ComputeTaskState state, final String failureMessage) {
+        if (task.isTerminal()) {
+            return;
+        }
+        task.failureMessage = failureMessage == null ? "" : failureMessage;
+        switch (state) {
+            case STALE -> this.diagnostics.stale(task.type);
+            case CANCELLED -> this.diagnostics.cancelled(task.type);
+            case FAILED -> this.diagnostics.failed(task.type);
+            case REJECTED -> this.diagnostics.rejected(task.type);
+            default -> {
+            }
+        }
+        task.transition(state);
+        this.releaseBudget(task);
+        this.evictTrackedTasks();
+    }
+
+    private void rejectNewTask(final ComputeTask<?, ?> task, final String reason) {
+        task.failureMessage = reason;
+        task.cancellationToken.cancel(reason);
+        task.transition(ComputeTaskState.REJECTED);
+        this.diagnostics.rejected(task.type);
+    }
+
+    private boolean reserveBudget(final ComputeTask<?, ?> task) {
+        if (!this.reserveType(task.type)) {
+            return false;
+        }
+        if (!this.reserve(task.owner.worldName(), this.inFlightByWorld, this.policy.maxQueuedComputeTasksPerWorld())) {
+            this.releaseType(task.type);
+            return false;
+        }
+        if (!this.reserve(task.owner.pluginName(), this.inFlightByPlugin, this.policy.maxQueuedComputeTasksPerPlugin())) {
+            this.release(task.owner.worldName(), this.inFlightByWorld);
+            this.releaseType(task.type);
+            return false;
+        }
+        return true;
+    }
+
+    private void releaseBudget(final ComputeTask<?, ?> task) {
+        this.releaseType(task.type);
+        this.release(task.owner.worldName(), this.inFlightByWorld);
+        this.release(task.owner.pluginName(), this.inFlightByPlugin);
+    }
+
+    private boolean reserveType(final ComputeTaskType type) {
+        final int limit = this.typeLimit(type);
+        if (limit <= 0) {
+            return true;
+        }
+        final AtomicInteger counter = this.inFlightByType.get(type);
+        for (;;) {
+            final int current = counter.get();
+            if (current >= limit) {
+                return false;
+            }
+            if (counter.compareAndSet(current, current + 1)) {
+                return true;
+            }
+        }
+    }
+
+    private void releaseType(final ComputeTaskType type) {
+        final AtomicInteger counter = this.inFlightByType.get(type);
+        if (counter != null) {
+            counter.updateAndGet(value -> Math.max(0, value - 1));
+        }
+    }
+
+    private int typeLimit(final ComputeTaskType type) {
+        return switch (type) {
+            case PATHFINDING -> this.policy.maxPathfindingTasksPerTick();
+            case EXPLOSION_PRECOMPUTE -> this.policy.maxExplosionPrecomputeTasksPerTick();
+            case CHUNK_SAVE_SERIALIZE -> this.policy.maxChunkSerializationTasks();
+            default -> 0;
+        };
+    }
+
+    private boolean reserve(final String key, final ConcurrentHashMap<String, AtomicInteger> counters, final int limit) {
+        if (key == null || key.isBlank()) {
+            return true;
+        }
+        final AtomicInteger counter = counters.computeIfAbsent(key, ignored -> new AtomicInteger());
+        for (;;) {
+            final int current = counter.get();
+            if (current >= limit) {
+                return false;
+            }
+            if (counter.compareAndSet(current, current + 1)) {
+                return true;
+            }
+        }
+    }
+
+    private void release(final String key, final ConcurrentHashMap<String, AtomicInteger> counters) {
+        if (key == null || key.isBlank()) {
+            return;
+        }
+        final AtomicInteger counter = counters.get(key);
+        if (counter == null) {
+            return;
+        }
+        final int remaining = counter.decrementAndGet();
+        if (remaining <= 0) {
+            counters.remove(key, counter);
+        }
+    }
+
+    private boolean isPastApplyDeadline(final ComputeTask<?, ?> task) {
+        return System.nanoTime() - task.submittedNanos > this.policy.maxApplyDelayMs() * 1_000_000L;
+    }
+
+    private <R extends ComputeResult> ComputeTaskHandle<R> handle(final ComputeTask<?, R> task) {
+        return new ComputeTaskHandle<>(task.id, task.cancellationToken, task.completion, task::snapshot);
+    }
+
+    private void track(final ComputeTask<?, ?> task) {
+        this.tasks.put(task.id, task);
+        this.taskOrder.add(task.id);
+        this.trackedTasks.incrementAndGet();
+        this.evictTrackedTasks();
+    }
+
+    private void evictTrackedTasks() {
+        final List<Long> deferred = new ArrayList<>();
+        try {
+            while (this.trackedTasks.get() > this.policy.maxTrackedTasks()) {
+                final Long id = this.taskOrder.poll();
+                if (id == null) {
+                    return;
+                }
+                final ComputeTask<?, ?> task = this.tasks.get(id);
+                if (task == null) {
+                    this.trackedTasks.decrementAndGet();
+                    continue;
+                }
+                if (!task.isTerminal()) {
+                    deferred.add(id);
+                    break;
+                }
+                if (this.tasks.remove(id, task)) {
+                    this.trackedTasks.decrementAndGet();
+                }
+            }
+        } finally {
+            for (final Long id : deferred) {
+                this.taskOrder.add(id);
+            }
+        }
+    }
+}
