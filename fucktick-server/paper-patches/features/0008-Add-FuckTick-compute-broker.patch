--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/compute/ComputeCancellationToken.java
@@ -0,0 +1,31 @@
+package io.papermc.paper.fucktick.compute;
+
+import java.util.concurrent.atomic.AtomicBoolean;
+
+public final class ComputeCancellationToken {
+
+    private final AtomicBoolean cancelled = new AtomicBoolean();
+    private volatile String reason = "";
+
+    public boolean cancel(final String reason) {
+        final boolean changed = this.cancelled.compareAndSet(false, true);
+        if (changed) {
+            this.reason = reason == null ? "" : reason;
+        }
+        return changed;
+    }
+
+    public boolean isCancelled() {
+        return this.cancelled.get();
+    }
+
+    public String reason() {
+        return this.reason;
+    }
+
+    public void throwIfCancelled() {
+        if (this.isCancelled()) {
+            throw new ComputeTaskCancelledException(this.reason);
+        }
+    }
+}
diff --git a/src/main/java/io/papermc/paper/fucktick/compute/ComputeDiagnostics.java b/src/main/java/io/papermc/paper/fucktick/compute/ComputeDiagnostics.java
new file mode 100644
index 0000000000000000000000000000000000000000..44e6e793ac5014cda1859d74a79073600babb903
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/compute/ComputeDiagnostics.java
@@ -0,0 +1,115 @@
+package io.papermc.paper.fucktick.compute;
+
+import java.util.Arrays;
+import java.util.EnumMap;
+import java.util.List;
+import java.util.concurrent.atomic.AtomicLong;
+
+final class ComputeDiagnostics {
+
+    private final EnumMap<ComputeTaskType, TypeStats> stats = new EnumMap<>(ComputeTaskType.class);
+
+    ComputeDiagnostics() {
+        for (final ComputeTaskType type : ComputeTaskType.values()) {
+            this.stats.put(type, new TypeStats(type));
+        }
+    }
+
+    void submitted(final ComputeTaskType type) {
+        this.stats.get(type).submitted.incrementAndGet();
+    }
+
+    void queued(final ComputeTaskType type) {
+        this.stats.get(type).queued.incrementAndGet();
+    }
+
+    void rejected(final ComputeTaskType type) {
+        this.stats.get(type).rejected.incrementAndGet();
+    }
+
+    void running(final ComputeTaskType type) {
+        this.stats.get(type).running.incrementAndGet();
+    }
+
+    void stoppedRunning(final ComputeTaskType type) {
+        this.stats.get(type).running.decrementAndGet();
+    }
+
+    void completed(final ComputeTaskType type, final long queueNanos, final long computeNanos) {
+        final TypeStats stats = this.stats.get(type);
+        stats.completed.incrementAndGet();
+        stats.queueObservations.incrementAndGet();
+        stats.totalQueueNanos.addAndGet(Math.max(0L, queueNanos));
+        stats.computeObservations.incrementAndGet();
+        stats.totalComputeNanos.addAndGet(Math.max(0L, computeNanos));
+    }
+
+    void applied(final ComputeTaskType type, final long applyDelayNanos) {
+        final TypeStats stats = this.stats.get(type);
+        stats.applied.incrementAndGet();
+        stats.applyDelayObservations.incrementAndGet();
+        stats.totalApplyDelayNanos.addAndGet(Math.max(0L, applyDelayNanos));
+    }
+
+    void stale(final ComputeTaskType type) {
+        this.stats.get(type).stale.incrementAndGet();
+    }
+
+    void cancelled(final ComputeTaskType type) {
+        this.stats.get(type).cancelled.incrementAndGet();
+    }
+
+    void failed(final ComputeTaskType type) {
+        this.stats.get(type).failed.incrementAndGet();
+    }
+
+    List<ComputeTaskTypeSnapshot> snapshot() {
+        return Arrays.stream(ComputeTaskType.values()).map(type -> this.stats.get(type).snapshot()).toList();
+    }
+
+    private static final class TypeStats {
+
+        private final ComputeTaskType type;
+        private final AtomicLong submitted = new AtomicLong();
+        private final AtomicLong queued = new AtomicLong();
+        private final AtomicLong running = new AtomicLong();
+        private final AtomicLong completed = new AtomicLong();
+        private final AtomicLong applied = new AtomicLong();
+        private final AtomicLong stale = new AtomicLong();
+        private final AtomicLong cancelled = new AtomicLong();
+        private final AtomicLong failed = new AtomicLong();
+        private final AtomicLong rejected = new AtomicLong();
+        private final AtomicLong queueObservations = new AtomicLong();
+        private final AtomicLong computeObservations = new AtomicLong();
+        private final AtomicLong applyDelayObservations = new AtomicLong();
+        private final AtomicLong totalQueueNanos = new AtomicLong();
+        private final AtomicLong totalComputeNanos = new AtomicLong();
+        private final AtomicLong totalApplyDelayNanos = new AtomicLong();
+
+        private TypeStats(final ComputeTaskType type) {
+            this.type = type;
+        }
+
+        private ComputeTaskTypeSnapshot snapshot() {
+            return new ComputeTaskTypeSnapshot(
+                this.type,
+                this.submitted.get(),
+                this.queued.get(),
+                this.running.get(),
+                this.completed.get(),
+                this.applied.get(),
+                this.stale.get(),
+                this.cancelled.get(),
+                this.failed.get(),
+                this.rejected.get(),
+                averageMillis(this.totalQueueNanos.get(), this.queueObservations.get()),
+                averageMillis(this.totalComputeNanos.get(), this.computeObservations.get()),
+                averageMillis(this.totalApplyDelayNanos.get(), this.applyDelayObservations.get())
+            );
+        }
+
+        private static double averageMillis(final long nanos, final long observations) {
+            return observations == 0L ? 0.0D : (nanos / 1_000_000.0D) / observations;
+        }
+    }
+}
