index 0000000000000000000000000000000000000000..d08ca3c6bb17da5eb2dae8fd7484987065af322d
--- /dev/null
+++ b/src/main/java/io/papermc/paper/command/FuckTickCommand.java
@@ -0,0 +1,118 @@
+package io.papermc.paper.command;
+
+import io.papermc.paper.fucktick.plugin.PluginFUCKLOADER;
+import io.papermc.paper.fucktick.plugin.PluginRuntimeSnapshot;
+import java.io.PrintWriter;
+import java.io.StringWriter;
+import java.util.List;
+import org.bukkit.Bukkit;
+import org.bukkit.command.Command;
+import org.bukkit.command.CommandSender;
+import org.bukkit.permissions.Permission;
+import org.bukkit.permissions.PermissionDefault;
+import org.jetbrains.annotations.NotNull;
+
+public final class FuckTickCommand extends Command {
+
+    public FuckTickCommand(final String name) {
+        super(name);
+        this.description = "FuckTick diagnostics";
+        this.usageMessage = "/fucktick plugins threads | /fucktick plugin <name> dump|queue|routing";
+        this.setPermission("bukkit.command.fucktick");
+        Bukkit.getPluginManager().addPermission(new Permission("bukkit.command.fucktick", PermissionDefault.OP));
+    }
+
+    @Override
+    public boolean execute(final @NotNull CommandSender sender, final @NotNull String commandLabel, final @NotNull String[] args) {
+        if (!this.testPermission(sender)) {
+            return true;
+        }
+        if (args.length >= 2 && args[0].equalsIgnoreCase("plugins") && args[1].equalsIgnoreCase("threads")) {
+            this.sendThreads(sender);
+            return true;
+        }
+        if (args.length >= 3 && args[0].equalsIgnoreCase("plugin")) {
+            final PluginRuntimeSnapshot snapshot = PluginFUCKLOADER.instance().snapshot(args[1]);
+            if (snapshot == null) {
+                sender.sendMessage("Unknown plugin runtime: " + args[1]);
+                return true;
+            }
+            switch (args[2].toLowerCase(java.util.Locale.ROOT)) {
+                case "dump" -> this.sendDump(sender, snapshot);
+                case "queue" -> this.sendQueue(sender, snapshot);
+                case "routing" -> this.sendRouting(sender, snapshot);
+                default -> sender.sendMessage("Usage: " + this.usageMessage);
+            }
+            return true;
+        }
+        sender.sendMessage("Usage: " + this.usageMessage);
+        return true;
+    }
+
+    @Override
+    public @NotNull List<String> tabComplete(final @NotNull CommandSender sender, final @NotNull String alias, final @NotNull String[] args) throws IllegalArgumentException {
+        if (args.length == 1) {
+            return io.papermc.paper.command.CommandUtil.getListMatchingLast(sender, args, List.of("plugins", "plugin"));
+        }
+        if (args.length == 2 && args[0].equalsIgnoreCase("plugins")) {
+            return io.papermc.paper.command.CommandUtil.getListMatchingLast(sender, args, List.of("threads"));
+        }
+        if (args.length == 2 && args[0].equalsIgnoreCase("plugin")) {
+            return io.papermc.paper.command.CommandUtil.getListMatchingLast(sender, args, PluginFUCKLOADER.instance().snapshots().stream().map(PluginRuntimeSnapshot::pluginName).toList());
+        }
+        if (args.length == 3 && args[0].equalsIgnoreCase("plugin")) {
+            return io.papermc.paper.command.CommandUtil.getListMatchingLast(sender, args, List.of("dump", "queue", "routing"));
+        }
+        return List.of();
+    }
+
+    private void sendThreads(final CommandSender sender) {
+        final List<PluginRuntimeSnapshot> snapshots = PluginFUCKLOADER.instance().snapshots();
+        if (snapshots.isEmpty()) {
+            sender.sendMessage("No plugin runtimes registered.");
+            return;
+        }
+        for (final PluginRuntimeSnapshot snapshot : snapshots) {
+            sender.sendMessage(snapshot.pluginName() + " state=" + snapshot.state() + " thread=\"" + snapshot.threadName() + "\" tid=" + snapshot.threadId() + " queued=" + snapshot.queuedTasks());
+        }
+    }
+
+    private void sendDump(final CommandSender sender, final PluginRuntimeSnapshot snapshot) {
+        sender.sendMessage("Plugin: " + snapshot.pluginName());
+        sender.sendMessage("State: " + snapshot.state());
+        sender.sendMessage("Thread: " + snapshot.threadName());
+        sender.sendMessage("ThreadId: " + snapshot.threadId());
+        sender.sendMessage("Queue size: " + snapshot.queuedTasks());
+        sender.sendMessage("Result queue size: " + snapshot.resultQueueSize());
+        sender.sendMessage("Running task: " + snapshot.runningTask());
+        sender.sendMessage("Last task duration: " + snapshot.lastTaskDurationMs() + "ms");
+        sender.sendMessage("Average task duration: " + snapshot.averageTaskDurationMs() + "ms");
+        sender.sendMessage("Blocked callers: " + snapshot.blockedCallers());
+        sender.sendMessage("Last owner context: " + snapshot.lastOwnerContext());
+        final Throwable failure = PluginFUCKLOADER.instance().failure(snapshot.pluginName());
+        if (failure != null) {
+            final StringWriter writer = new StringWriter();
+            failure.printStackTrace(new PrintWriter(writer));
+            sender.sendMessage("Failure: " + writer);
+        }
+    }
+
+    private void sendQueue(final CommandSender sender, final PluginRuntimeSnapshot snapshot) {
+        sender.sendMessage("Plugin: " + snapshot.pluginName());
+        sender.sendMessage("Lifecycle queue size: " + snapshot.lifecycleQueuedTasks());
+        sender.sendMessage("Callback queue size: " + snapshot.queuedTasks());
+        sender.sendMessage("Result queue size: " + snapshot.resultQueueSize());
+        sender.sendMessage("Blocked callers: " + snapshot.blockedCallers());
+    }
+
+    private void sendRouting(final CommandSender sender, final PluginRuntimeSnapshot snapshot) {
+        sender.sendMessage("Plugin: " + snapshot.pluginName());
+        sender.sendMessage("Commands: plugin-thread blocking result");
+        sender.sendMessage("Tab-complete: plugin-thread blocking result");
+        sender.sendMessage("AsyncScheduler: plugin-thread");
+        sender.sendMessage("RegionScheduler: owner-thread");
+        sender.sendMessage("EntityScheduler: owner-thread");
+        sender.sendMessage("GlobalRegionScheduler: owner-thread");
+        sender.sendMessage("Unknown events: owner-only");
+    }
+}
