@@ -127,8 +129,27 @@ public final class FoliaAsyncScheduler implements AsyncScheduler {
         return this.scheduleTimerTask(plugin, task, initialDelay, period, unit);
     }
 
+    // FuckTick Start - подавление штатных отказов runtime при остановке
+    private void handlePluginThreadQueueFailure(final Plugin plugin, final AsyncScheduledTask task, final Throwable throwable) {
+        task.cancel();
+        final Throwable cause = unwrapCompletionFailure(throwable);
+        if (cause instanceof final PluginRuntimeRejectedException rejectedException && rejectedException.isShutdownState()) {
+            return;
+        }
+        plugin.getLogger().log(Level.WARNING, "Async task for " + plugin.getDescription().getFullName() + " could not be queued on plugin thread", throwable);
+    }
+
+    private static Throwable unwrapCompletionFailure(final Throwable throwable) {
+        Throwable current = throwable;
+        while ((current instanceof CompletionException || current instanceof ExecutionException) && current.getCause() != null) {
+            current = current.getCause();
+        }
+        return current;
+    }
+    // FuckTick End
+
     private AsyncScheduledTask scheduleTimerTask(final Plugin plugin, final Consumer<ScheduledTask> task, final long initialDelay,
-                                                 final long period, final TimeUnit unit) {
+                                                  final long period, final TimeUnit unit) {
         final AsyncScheduledTask ret = new AsyncScheduledTask(
             plugin, period <= 0 ? period : unit.toNanos(period), task, null,
             System.nanoTime() + unit.toNanos(initialDelay)
@@ -216,11 +237,10 @@ public final class FoliaAsyncScheduler implements AsyncScheduler {
             if (timer) {
                 // the scheduled executor is single thread, and unfortunately not expandable with threads
                 // so we just schedule onto the executor
-                // FuckTick Start - таймер передает async task в очередь плагина
-                PluginFUCKLOADER.instance().executePluginTask(this.plugin, "async-scheduler:timer", this).whenComplete((ignored, throwable) -> {
+                // FuckTick Start - таймер передает асинхронную задачу в очередь без прямого запуска
+                PluginFUCKLOADER.instance().executePluginTaskDeferred(this.plugin, "async-scheduler:timer", this).whenComplete((ignored, throwable) -> {
                     if (throwable != null) {
-                        this.cancel();
-                        this.plugin.getLogger().log(Level.WARNING, "Async task for " + this.plugin.getDescription().getFullName() + " could not be queued on plugin thread", throwable);
+                        FoliaAsyncScheduler.this.handlePluginThreadQueueFailure(this.plugin, this, throwable);
                     }
                 });
                 // FuckTick End
