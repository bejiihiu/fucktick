     }
 
+    public CompletableFuture<R> result() {
+        return this.result;
+    }
+
+    public R awaitResultOrFallback(final long timeout, final TimeUnit unit, final Supplier<R> fallback) {
+        if (FuckTickComputeContext.isComputeWorker()) {
+            throw new IllegalStateException("Compute task " + FuckTickComputeContext.currentTaskType() + " attempted to wait for another compute result from a compute worker.");
+        }
+        if (BLOCKING_WAIT_ACTIVE.get()) {
+            throw new IllegalStateException("Nested owner wait for compute task " + this.taskId + " is forbidden.");
+        }
+        BLOCKING_WAIT_ACTIVE.set(Boolean.TRUE);
+        try {
+            return this.result.get(timeout, unit);
+        } catch (final TimeoutException ex) {
+            this.cancel("Timed out waiting for compute result");
+            LOGGER.warn("FuckTick compute result wait timed out. id={} timeout={}{} possibleDeadlock=true", this.taskId, timeout, unit);
+            return fallback.get();
+        } catch (final Exception ex) {
+            LOGGER.warn("FuckTick compute result wait failed. id={} fallback=true", this.taskId, ex);
+            return fallback.get();
+        } finally {
+            BLOCKING_WAIT_ACTIVE.set(Boolean.FALSE);
+        }
+    }
+
     public ComputeTaskSnapshot snapshot() {
         return this.snapshotSupplier.get();
     }
