+package io.papermc.paper.fucktick.compute;
+
+import io.papermc.paper.fucktick.compute.workload.ChunkSavePayloadResult;
+import io.papermc.paper.fucktick.compute.workload.ChunkSaveWriteResult;
+import java.io.IOException;
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.nio.file.StandardCopyOption;
+import java.util.Objects;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ExecutorService;
+import java.util.concurrent.Executors;
+import java.util.concurrent.ThreadFactory;
+import java.util.concurrent.TimeUnit;
+import java.util.concurrent.atomic.AtomicInteger;
+import java.util.concurrent.atomic.AtomicReference;
+
+public final class FuckTickComputeIoWorkerPool {
+
+    private static final AtomicReference<FuckTickComputeIoWorkerPool> INSTANCE = new AtomicReference<>();
+
+    private final ExecutorService workers;
+
+    public static FuckTickComputeIoWorkerPool instance() {
+        final FuckTickComputeIoWorkerPool current = INSTANCE.get();
+        if (current != null) {
+            return current;
+        }
+        final FuckTickComputeIoWorkerPool created = new FuckTickComputeIoWorkerPool();
+        if (INSTANCE.compareAndSet(null, created)) {
+            return created;
+        }
+        created.shutdown();
+        return INSTANCE.get();
+    }
+
+    public static void shutdownIfInitialized() {
+        final FuckTickComputeIoWorkerPool current = INSTANCE.get();
+        if (current != null) {
+            current.shutdown();
+        }
+    }
+
+    private FuckTickComputeIoWorkerPool() {
+        this.workers = Executors.newFixedThreadPool(readWorkerCount(), new IoThreadFactory());
+    }
+
+    public CompletableFuture<ChunkSaveWriteResult> writeChunkPayload(final Path target, final ChunkSavePayloadResult payload) {
+        Objects.requireNonNull(target, "target");
+        Objects.requireNonNull(payload, "payload");
+        if (FuckTickComputeContext.isComputeWorker()) {
+            throw new IllegalStateException("Compute worker must not perform chunk save IO directly.");
+        }
+        return CompletableFuture.supplyAsync(() -> writePayload(target, payload), this.workers);
+    }
+
+    public void shutdown() {
+        this.workers.shutdownNow();
+        try {
+            this.workers.awaitTermination(readShutdownWaitMs(), TimeUnit.MILLISECONDS);
+        } catch (final InterruptedException ex) {
+            Thread.currentThread().interrupt();
+        }
+    }
+
+    private static ChunkSaveWriteResult writePayload(final Path target, final ChunkSavePayloadResult payload) {
+        try {
+            final Path parent = target.toAbsolutePath().getParent();
+            if (parent != null) {
+                Files.createDirectories(parent);
+            }
+            final Path temp = target.resolveSibling(target.getFileName() + ".tmp");
+            final byte[] bytes = payload.compressedPayload();
+            Files.write(temp, bytes);
+            Files.move(temp, target, StandardCopyOption.REPLACE_EXISTING, StandardCopyOption.ATOMIC_MOVE);
+            return new ChunkSaveWriteResult(payload.generation(), payload.worldName(), payload.chunkX(), payload.chunkZ(), target, payload.checksum(), bytes.length, Thread.currentThread().getName());
+        } catch (final IOException ex) {
+            throw new IllegalStateException("Chunk save payload write failed: " + target, ex);
+        }
+    }
+
+    private static int readWorkerCount() {
+        final String value = System.getProperty("fucktick.compute.ioWorkers");
+        if (value == null || value.isBlank()) {
+            return 1;
+        }
+        try {
+            return Math.max(1, Integer.parseInt(value));
+        } catch (final NumberFormatException ex) {
+            return 1;
+        }
+    }
+
+    private static long readShutdownWaitMs() {
+        final String value = System.getProperty("fucktick.compute.ioShutdownWaitMs");
+        if (value == null || value.isBlank()) {
+            return 5_000L;
+        }
+        try {
+            return Math.max(1L, Long.parseLong(value));
+        } catch (final NumberFormatException ex) {
+            return 5_000L;
+        }
+    }
+
+    private static final class IoThreadFactory implements ThreadFactory {
+
+        private final AtomicInteger ids = new AtomicInteger();
+
+        @Override
+        public Thread newThread(final Runnable runnable) {
+            final Thread thread = new Thread(runnable, "FuckTick Compute IO Worker - " + this.ids.incrementAndGet());
+            thread.setDaemon(true);
+            return thread;
+        }
+    }
+}
