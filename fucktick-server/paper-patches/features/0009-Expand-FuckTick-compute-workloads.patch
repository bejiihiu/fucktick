diff --git a/src/main/java/io/papermc/paper/fucktick/compute/workload/FuckTickComputeWorkloads.java b/src/main/java/io/papermc/paper/fucktick/compute/workload/FuckTickComputeWorkloads.java
new file mode 100644
index 0000000000000000000000000000000000000000..de3607bea42a435a3258868c9eff38eb18d3daef
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/compute/workload/FuckTickComputeWorkloads.java
@@ -0,0 +1,289 @@
+package io.papermc.paper.fucktick.compute.workload;
+
+import io.papermc.paper.fucktick.compute.ComputeCancellationToken;
+import io.papermc.paper.fucktick.compute.ComputeTaskCancelledException;
+import java.io.ByteArrayOutputStream;
+import java.io.IOException;
+import java.security.MessageDigest;
+import java.security.NoSuchAlgorithmException;
+import java.util.ArrayDeque;
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.HashMap;
+import java.util.HashSet;
+import java.util.List;
+import java.util.Locale;
+import java.util.Map;
+import java.util.Objects;
+import java.util.Set;
+import java.util.zip.GZIPOutputStream;
+
+public final class FuckTickComputeWorkloads {
+
+    private static final int MAX_PATH_NODES = 4096;
+
+    private FuckTickComputeWorkloads() {
+    }
+
+    public static PathfindingPlanResult pathfinding(final EntityPathfindingSnapshot snapshot, final ComputeCancellationToken token) {
+        Objects.requireNonNull(snapshot, "snapshot");
+        checkCancelled(token);
+        final BlockNode start = BlockNode.from(snapshot.currentPosition());
+        final BlockNode target = BlockNode.from(snapshot.targetPosition());
+        if (start.equals(target)) {
+            return new PathfindingPlanResult(snapshot.generation(), snapshot.entityId(), snapshot.worldName(), List.of(snapshot.currentPosition()), false);
+        }
+        final Set<BlockNode> blocked = new HashSet<>();
+        final Set<BlockNode> sampled = new HashSet<>();
+        for (final BlockCollisionComputeSnapshot block : snapshot.nearbyCollision()) {
+            final BlockNode node = new BlockNode(block.x(), block.y(), block.z());
+            sampled.add(node);
+            if (block.solid()) {
+                blocked.add(node);
+            }
+        }
+        if (sampled.isEmpty()) {
+            return new PathfindingPlanResult(snapshot.generation(), snapshot.entityId(), snapshot.worldName(), List.of(snapshot.currentPosition(), snapshot.targetPosition()), false);
+        }
+        final Bounds bounds = Bounds.from(sampled, start, target);
+        final ArrayDeque<BlockNode> queue = new ArrayDeque<>();
+        final Map<BlockNode, BlockNode> previous = new HashMap<>();
+        final Set<BlockNode> seen = new HashSet<>();
+        queue.add(start);
+        seen.add(start);
+        BlockNode closest = start;
+        while (!queue.isEmpty() && seen.size() <= MAX_PATH_NODES) {
+            checkCancelled(token);
+            final BlockNode current = queue.removeFirst();
+            if (current.distanceSquared(target) < closest.distanceSquared(target)) {
+                closest = current;
+            }
+            if (current.equals(target)) {
+                return new PathfindingPlanResult(snapshot.generation(), snapshot.entityId(), snapshot.worldName(), toLocations(snapshot.worldName(), snapshot.currentPosition(), snapshot.targetPosition(), previous, target), false);
+            }
+            for (final BlockNode next : current.neighbours()) {
+                if (!bounds.contains(next) || blocked.contains(next) || !seen.add(next)) {
+                    continue;
+                }
+                previous.put(next, current);
+                queue.addLast(next);
+            }
+        }
+        return new PathfindingPlanResult(snapshot.generation(), snapshot.entityId(), snapshot.worldName(), toLocations(snapshot.worldName(), snapshot.currentPosition(), snapshot.targetPosition(), previous, closest), true);
+    }
+
+    public static ExplosionPlanResult explosionPrecompute(final ExplosionSnapshot snapshot, final ComputeCancellationToken token) {
+        Objects.requireNonNull(snapshot, "snapshot");
+        checkCancelled(token);
+        final double radius = Math.max(0.0D, snapshot.power()) * 2.0D;
+        final List<AffectedBlockSnapshot> affected = snapshot.sampledBlocks().stream()
+            .peek(ignored -> checkCancelled(token))
+            .filter(block -> explosionReach(snapshot.center(), block, radius) > 0.0D)
+            .sorted(Comparator.comparingDouble(block -> distanceSquared(snapshot.center(), block.x(), block.y(), block.z())))
+            .map(block -> new AffectedBlockSnapshot(block.x(), block.y(), block.z(), block.blockKey()))
+            .toList();
+        return new ExplosionPlanResult(snapshot.generation(), snapshot.explosionId(), snapshot.worldName(), affected, List.of());
+    }
+
+    public static ChunkSavePayloadResult chunkSaveSerialize(final ChunkSaveSnapshot snapshot, final ComputeCancellationToken token) {
+        Objects.requireNonNull(snapshot, "snapshot");
+        checkCancelled(token);
+        final byte[] compressed = gzip(snapshot.uncompressedPayload(), token);
+        return new ChunkSavePayloadResult(snapshot.generation(), snapshot.worldName(), snapshot.chunkX(), snapshot.chunkZ(), compressed, sha256(compressed));
+    }
+
+    public static ScoreboardRenderResult scoreboardRender(final ScoreboardRenderSnapshot snapshot, final ComputeCancellationToken token) {
+        Objects.requireNonNull(snapshot, "snapshot");
+        final List<Map.Entry<String, String>> placeholders = snapshot.placeholders().entrySet().stream()
+            .sorted(Comparator.comparingInt((Map.Entry<String, String> entry) -> entry.getKey().length()).reversed())
+            .toList();
+        final List<String> rendered = new ArrayList<>(snapshot.templateLines().size());
+        for (final String line : snapshot.templateLines()) {
+            checkCancelled(token);
+            String value = line;
+            for (final Map.Entry<String, String> placeholder : placeholders) {
+                value = value.replace(placeholder.getKey(), placeholder.getValue());
+            }
+            rendered.add(value);
+        }
+        return new ScoreboardRenderResult(snapshot.generation(), snapshot.playerId(), rendered);
+    }
+
+    public static DiagnosticFormattingResult diagnosticFormat(final DiagnosticFormattingSnapshot snapshot, final ComputeCancellationToken token) {
+        Objects.requireNonNull(snapshot, "snapshot");
+        final StringBuilder builder = new StringBuilder();
+        builder.append(snapshot.reportName()).append(':').append('\n');
+        snapshot.counters().entrySet().stream()
+            .sorted(Map.Entry.comparingByKey())
+            .forEach(entry -> {
+                checkCancelled(token);
+                builder.append(entry.getKey()).append('=').append(entry.getValue()).append('\n');
+            });
+        for (final String section : snapshot.sections()) {
+            checkCancelled(token);
+            builder.append(section).append('\n');
+        }
+        return new DiagnosticFormattingResult(snapshot.generation(), snapshot.reportName(), builder.toString().stripTrailing());
+    }
+
+    public static RoutingMetadataWarmupResult routingMetadataWarmup(final RoutingMetadataWarmupSnapshot snapshot, final ComputeCancellationToken token) {
+        Objects.requireNonNull(snapshot, "snapshot");
+        final List<String> warnings = new ArrayList<>();
+        for (final String listener : snapshot.listenerClassNames()) {
+            checkCancelled(token);
+            if (listener == null || listener.isBlank()) {
+                warnings.add("Blank listener class name for plugin " + snapshot.pluginName());
+            } else if (!listener.contains(".")) {
+                warnings.add("Listener class has no package: " + listener);
+            }
+        }
+        final Set<String> commands = new HashSet<>();
+        for (final String command : snapshot.commandNames()) {
+            checkCancelled(token);
+            final String normalized = command == null ? "" : command.toLowerCase(Locale.ROOT);
+            if (normalized.isBlank()) {
+                warnings.add("Blank command name for plugin " + snapshot.pluginName());
+            } else if (!commands.add(normalized)) {
+                warnings.add("Duplicate command metadata: " + command);
+            }
+        }
+        return new RoutingMetadataWarmupResult(snapshot.generation(), snapshot.pluginName(), snapshot.listenerClassNames().size(), snapshot.commandNames().size(), warnings);
+    }
+
+    private static List<LocationComputeSnapshot> toLocations(
+        final String worldName,
+        final LocationComputeSnapshot first,
+        final LocationComputeSnapshot target,
+        final Map<BlockNode, BlockNode> previous,
+        final BlockNode end
+    ) {
+        final ArrayDeque<BlockNode> reversed = new ArrayDeque<>();
+        BlockNode current = end;
+        reversed.addFirst(current);
+        while (previous.containsKey(current)) {
+            current = previous.get(current);
+            reversed.addFirst(current);
+        }
+        final List<LocationComputeSnapshot> path = new ArrayList<>(reversed.size());
+        for (final BlockNode node : reversed) {
+            path.add(new LocationComputeSnapshot(worldName, node.x() + 0.5D, node.y(), node.z() + 0.5D, first.yaw(), first.pitch()));
+        }
+        if (!path.isEmpty()) {
+            path.set(0, first);
+        }
+        if (end.equals(BlockNode.from(target)) && !path.isEmpty()) {
+            path.set(path.size() - 1, target);
+        }
+        return path;
+    }
+
+    private static double explosionReach(final LocationComputeSnapshot center, final BlockCollisionComputeSnapshot block, final double radius) {
+        final double distance = Math.sqrt(distanceSquared(center, block.x(), block.y(), block.z()));
+        if (distance > radius) {
+            return -1.0D;
+        }
+        return radius - distance - Math.max(0.0F, block.explosionResistance()) * 0.1D;
+    }
+
+    private static double distanceSquared(final LocationComputeSnapshot center, final int x, final int y, final int z) {
+        final double dx = center.x() - (x + 0.5D);
+        final double dy = center.y() - (y + 0.5D);
+        final double dz = center.z() - (z + 0.5D);
+        return dx * dx + dy * dy + dz * dz;
+    }
+
+    private static byte[] gzip(final byte[] input, final ComputeCancellationToken token) {
+        try {
+            final ByteArrayOutputStream output = new ByteArrayOutputStream();
+            try (GZIPOutputStream gzip = new GZIPOutputStream(output)) {
+                int offset = 0;
+                while (offset < input.length) {
+                    checkCancelled(token);
+                    final int length = Math.min(8192, input.length - offset);
+                    gzip.write(input, offset, length);
+                    offset += length;
+                }
+            }
+            return output.toByteArray();
+        } catch (final IOException ex) {
+            throw new IllegalStateException("Chunk save payload compression failed", ex);
+        }
+    }
+
+    private static String sha256(final byte[] bytes) {
+        try {
+            final MessageDigest digest = MessageDigest.getInstance("SHA-256");
+            final byte[] hashed = digest.digest(bytes);
+            final StringBuilder builder = new StringBuilder(hashed.length * 2);
+            for (final byte value : hashed) {
+                builder.append(String.format(Locale.ROOT, "%02x", value & 0xff));
+            }
+            return builder.toString();
+        } catch (final NoSuchAlgorithmException ex) {
+            throw new IllegalStateException("SHA-256 is unavailable", ex);
+        }
+    }
+
+    private static void checkCancelled(final ComputeCancellationToken token) {
+        if (token != null && token.isCancelled()) {
+            throw new ComputeTaskCancelledException(token.reason());
+        }
+    }
+
+    private record BlockNode(int x, int y, int z) {
+
+        private static BlockNode from(final LocationComputeSnapshot location) {
+            return new BlockNode(floor(location.x()), floor(location.y()), floor(location.z()));
+        }
+
+        private List<BlockNode> neighbours() {
+            return List.of(
+                new BlockNode(this.x + 1, this.y, this.z),
+                new BlockNode(this.x - 1, this.y, this.z),
+                new BlockNode(this.x, this.y, this.z + 1),
+                new BlockNode(this.x, this.y, this.z - 1),
+                new BlockNode(this.x, this.y + 1, this.z),
+                new BlockNode(this.x, this.y - 1, this.z)
+            );
+        }
+
+        private int distanceSquared(final BlockNode other) {
+            final int dx = this.x - other.x;
+            final int dy = this.y - other.y;
+            final int dz = this.z - other.z;
+            return dx * dx + dy * dy + dz * dz;
+        }
+    }
+
+    private record Bounds(int minX, int maxX, int minY, int maxY, int minZ, int maxZ) {
+
+        private static Bounds from(final Set<BlockNode> sampled, final BlockNode start, final BlockNode target) {
+            int minX = Math.min(start.x(), target.x());
+            int maxX = Math.max(start.x(), target.x());
+            int minY = Math.min(start.y(), target.y());
+            int maxY = Math.max(start.y(), target.y());
+            int minZ = Math.min(start.z(), target.z());
+            int maxZ = Math.max(start.z(), target.z());
+            for (final BlockNode node : sampled) {
+                minX = Math.min(minX, node.x());
+                maxX = Math.max(maxX, node.x());
+                minY = Math.min(minY, node.y());
+                maxY = Math.max(maxY, node.y());
+                minZ = Math.min(minZ, node.z());
+                maxZ = Math.max(maxZ, node.z());
+            }
+            return new Bounds(minX - 1, maxX + 1, minY - 1, maxY + 1, minZ - 1, maxZ + 1);
+        }
+
+        private boolean contains(final BlockNode node) {
+            return node.x() >= this.minX && node.x() <= this.maxX
+                && node.y() >= this.minY && node.y() <= this.maxY
+                && node.z() >= this.minZ && node.z() <= this.maxZ;
+        }
+    }
+
+    private static int floor(final double value) {
+        final int integer = (int)value;
+        return value < integer ? integer - 1 : integer;
+    }
+}
