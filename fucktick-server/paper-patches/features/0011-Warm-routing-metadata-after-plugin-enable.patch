+    // FuckTick Start - фоновый прогрев routing metadata через compute broker
+    private void warmupRoutingMetadata(final Plugin plugin) {
+        final String pluginName = plugin.getName();
+        final java.util.logging.Logger serverLogger = this.server.getLogger();
+        final List<String> listenerClassNames = HandlerList.getRegisteredListeners(plugin).stream()
+            .map(RegisteredListener::getListener)
+            .map(listener -> listener.getClass().getName())
+            .distinct()
+            .sorted(String.CASE_INSENSITIVE_ORDER)
+            .toList();
+        final List<String> commandNames = this.commandMap instanceof SimpleCommandMap simpleCommandMap
+            ? simpleCommandMap.getKnownCommands().entrySet().stream()
+                .filter(entry -> entry.getValue() instanceof PluginIdentifiableCommand command && command.getPlugin().equals(plugin))
+                .map(Map.Entry::getKey)
+                .distinct()
+                .sorted(String.CASE_INSENSITIVE_ORDER)
+                .toList()
+            : List.of();
+        final RoutingMetadataWarmupSnapshot snapshot = new RoutingMetadataWarmupSnapshot(
+            ComputeGeneration.of(System.nanoTime()),
+            pluginName,
+            listenerClassNames,
+            commandNames
+        );
+        final ComputeTaskHandle<RoutingMetadataWarmupResult> handle = FuckTickComputeBroker.instance().submit(
+            ComputeTaskType.ROUTING_METADATA_WARMUP,
+            ComputePriority.BACKGROUND_WARMUP,
+            new ComputeTaskOwner(null, pluginName),
+            "routing metadata warmup for " + pluginName,
+            snapshot,
+            FuckTickComputeWorkloads::routingMetadataWarmup,
+            Runnable::run,
+            (context, result) -> ComputeApplyDecision.APPLIED
+        );
+        handle.result().whenComplete((result, throwable) -> {
+            if (throwable != null) {
+                serverLogger.log(Level.WARNING, "FuckTick routing metadata warmup failed for " + pluginName, throwable);
+            }
+        });
+    }
+    // FuckTick End
+
