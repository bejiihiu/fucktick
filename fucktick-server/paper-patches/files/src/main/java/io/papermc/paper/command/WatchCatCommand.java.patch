+    private void sendRouting(final CommandSender sender, final PluginRuntimeSnapshot snapshot) {
+        final RoutingMetadataWarmupSnapshot routingSnapshot = new RoutingMetadataWarmupSnapshot(
+            ComputeGeneration.of(System.nanoTime()),
+            snapshot.pluginName(),
+            List.of(snapshot.pluginName() + ".runtime"),
+            List.of("commands", "tab-complete", "asyncScheduler", "regionScheduler", "entityScheduler", "globalScheduler")
+        );
+        final ComputeTaskHandle<RoutingMetadataWarmupResult> handle = FuckTickComputeBroker.instance().submit(
+            ComputeTaskType.ROUTING_METADATA_WARMUP,
+            ComputePriority.BACKGROUND_WARMUP,
+            new ComputeTaskOwner(null, snapshot.pluginName()),
+            "routing metadata warmup for " + snapshot.pluginName(),
+            routingSnapshot,
+            FuckTickComputeWorkloads::routingMetadataWarmup,
+            Runnable::run,
+            (context, result) -> ComputeApplyDecision.APPLIED
+        );
+        final RoutingMetadataWarmupResult result = handle.awaitResultOrFallback(250L, TimeUnit.MILLISECONDS, () -> FuckTickComputeWorkloads.routingMetadataWarmup(routingSnapshot, new ComputeCancellationToken()));
+        final List<String> sections = new ArrayList<>();
+        sections.add("Plugin: " + snapshot.pluginName());
+        sections.add("Commands: plugin-thread blocking result");
+        sections.add("Tab-complete: plugin-thread blocking result");
+        sections.add("AsyncScheduler: plugin-thread");
+        sections.add("RegionScheduler: owner-thread");
+        sections.add("EntityScheduler: owner-thread");
+        sections.add("GlobalRegionScheduler: owner-thread");
+        sections.add("Unknown events: owner-only");
+        result.warnings().forEach(warning -> sections.add("Warning: " + warning));
+        this.sendDiagnostic(sender, "Plugin routing", Map.of(
+            "listenersScanned", Integer.toString(result.listenersScanned()),
+            "commandsScanned", Integer.toString(result.commandsScanned())
+        ), sections);
+    }
