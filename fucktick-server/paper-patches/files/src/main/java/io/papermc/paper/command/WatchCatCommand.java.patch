+    // FuckTick Start - вывод состояния WatchCat
+    private void sendWatchCatStatus(final CommandSender sender) {
+        final List<WatchCatTargetSnapshot> targets = WatchCat.instance().targetSnapshots();
+        final long alive = targets.stream().filter(WatchCatTargetSnapshot::alive).count();
+        this.sendDiagnostic(sender, "WatchCat", Map.of(
+            "running", Boolean.toString(WatchCat.instance().isRunning()),
+            "targets", Integer.toString(targets.size()),
+            "alive", Long.toString(alive),
+            "incidents", Integer.toString(WatchCat.instance().incidents().size()),
+            "heartbeatTimeout", WatchCatSettings.heartbeatTimeoutMs() + "ms"
+        ), targets.stream()
+            .limit(10L)
+            .map(target -> target.id() + " kind=" + target.kind() + " state=" + target.state() + " alive=" + target.alive())
+            .toList());
+    }
+
