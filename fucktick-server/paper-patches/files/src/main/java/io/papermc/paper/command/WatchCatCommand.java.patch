+    private void sendWatchCatTargetDump(final CommandSender sender, final WatchCatTargetSnapshot snapshot) {
+        final Map<String, String> counters = new LinkedHashMap<>();
+        counters.put("kind", snapshot.kind().name());
+        counters.put("threadId", Long.toString(snapshot.threadId()));
+        counters.put("alive", Boolean.toString(snapshot.alive()));
+        counters.put("state", snapshot.state());
+        final List<String> sections = new ArrayList<>();
+        sections.add("Target: " + snapshot.id());
+        sections.add("Display: " + snapshot.displayName());
+        sections.add("Thread: " + blankDash(snapshot.threadName()));
+        snapshot.details().forEach((key, value) -> sections.add(key + ": " + value));
+        this.sendDiagnostic(sender, "WatchCat target", counters, sections);
+    }
