+    // FuckTick Start - вывод состояния compute broker
+    private void sendCompute(final CommandSender sender, final String[] args) {
+        final ComputeBrokerSnapshot snapshot = FuckTickComputeBroker.instance().snapshot();
+        switch (args[1].toLowerCase(java.util.Locale.ROOT)) {
+            case "status" -> this.sendComputeStatus(sender, snapshot);
+            case "workers" -> this.sendComputeWorkers(sender, snapshot);
+            case "queue" -> this.sendComputeQueue(sender, snapshot);
+            case "tasks" -> this.sendComputeTasks(sender, snapshot);
+            case "task" -> {
+                if (args.length < 3) {
+                    sender.sendMessage("Usage: /watchcat compute task <id>");
+                    return;
+                }
+                try {
+                    this.sendComputeTask(sender, Long.parseLong(args[2]));
+                } catch (final NumberFormatException ex) {
+                    sender.sendMessage("Compute task id must be a number: " + args[2]);
+                }
+            }
+            default -> sender.sendMessage("Usage: " + this.usageMessage);
+        }
+    }
+
+    private void sendComputeStatus(final CommandSender sender, final ComputeBrokerSnapshot snapshot) {
+        final long completed = snapshot.taskTypes().stream().mapToLong(ComputeTaskTypeSnapshot::completed).sum();
+        final long applied = snapshot.taskTypes().stream().mapToLong(ComputeTaskTypeSnapshot::applied).sum();
+        final long stale = snapshot.taskTypes().stream().mapToLong(ComputeTaskTypeSnapshot::stale).sum();
+        final long rejected = snapshot.taskTypes().stream().mapToLong(ComputeTaskTypeSnapshot::rejected).sum();
+        final List<String> sections = new ArrayList<>();
+        sections.add("Top task types:");
+        snapshot.taskTypes().stream()
+            .filter(type -> type.submitted() > 0L || type.rejected() > 0L)
+            .sorted(Comparator.comparingLong(ComputeTaskTypeSnapshot::submitted).reversed())
+            .limit(8L)
+            .forEach(type -> sections.add(type.type()
+                + " queued=" + type.queued()
+                + " running=" + type.running()
+                + " avgCompute=" + ONE_DECIMAL.get().format(type.averageComputeTimeMs()) + "ms"
+                + " stale=" + type.stale()
+                + " rejected=" + type.rejected()));
+        this.sendDiagnostic(sender, "Compute Broker", Map.of(
+            "workers", Integer.toString(snapshot.workerCount()),
+            "queued", Integer.toString(snapshot.queuedTasks()),
+            "running", Integer.toString(snapshot.runningTasks()),
+            "completed", Long.toString(completed),
+            "applied", Long.toString(applied),
+            "stale", Long.toString(stale),
+            "rejected", Long.toString(rejected),
+            "shutdown", Boolean.toString(snapshot.shutdown())
+        ), sections);
+    }
+
+    private void sendComputeWorkers(final CommandSender sender, final ComputeBrokerSnapshot snapshot) {
+        this.sendDiagnostic(sender, "Compute workers", Map.of("workers", Integer.toString(snapshot.workers().size())), snapshot.workers().stream()
+            .map(worker -> worker.name() + " alive=" + worker.alive() + " task=" + (worker.taskId() == null ? "-" : worker.taskId()))
+            .toList());
+    }
+
+    private void sendComputeQueue(final CommandSender sender, final ComputeBrokerSnapshot snapshot) {
+        final List<ComputeTaskSnapshot> queued = snapshot.tasks().stream()
+            .filter(task -> task.state() == ComputeTaskState.QUEUED || task.state() == ComputeTaskState.SNAPSHOTTED || task.state() == ComputeTaskState.SUBMITTED)
+            .sorted(Comparator.comparing(ComputeTaskSnapshot::priority).thenComparingLong(ComputeTaskSnapshot::id))
+            .limit(20L)
+            .toList();
+        if (queued.isEmpty()) {
+            sender.sendMessage("Compute queue is empty.");
+            return;
+        }
+        this.sendDiagnostic(sender, "Compute queue", Map.of("queued", Integer.toString(queued.size())), queued.stream().map(this::formatComputeTaskLine).toList());
+    }
+
+    private void sendComputeTasks(final CommandSender sender, final ComputeBrokerSnapshot snapshot) {
+        final List<ComputeTaskSnapshot> tasks = snapshot.tasks().stream().limit(20L).toList();
+        if (tasks.isEmpty()) {
+            sender.sendMessage("No compute tasks tracked.");
+            return;
+        }
+        this.sendDiagnostic(sender, "Compute tasks", Map.of("tracked", Integer.toString(tasks.size())), tasks.stream().map(this::formatComputeTaskLine).toList());
+    }
+
+    private void sendComputeTask(final CommandSender sender, final long taskId) {
+        final ComputeTaskSnapshot task = FuckTickComputeBroker.instance().taskSnapshot(taskId);
+        if (task == null) {
+            sender.sendMessage("Unknown compute task: " + taskId);
+            return;
+        }
+        final Map<String, String> counters = new LinkedHashMap<>();
+        counters.put("id", Long.toString(task.id()));
+        counters.put("generation", Long.toString(task.generation().value()));
+        counters.put("queueTime", millisOrDash(task.queueTimeMs()));
+        counters.put("computeTime", millisOrDash(task.computeTimeMs()));
+        counters.put("applyDelay", millisOrDash(task.applyDelayMs()));
+        final List<String> sections = new ArrayList<>();
+        sections.add("Type: " + task.type());
+        sections.add("Priority: " + task.priority());
+        sections.add("State: " + task.state());
+        sections.add("Owner: " + task.owner().displayName());
+        sections.add("Description: " + task.description());
+        sections.add("Worker thread: " + blankDash(task.workerThread()));
+        sections.add("Apply thread: " + blankDash(task.applyThread()));
+        if (task.cancelled()) {
+            sections.add("Cancellation: " + blankDash(task.cancellationReason()));
+        }
+        if (!task.failureMessage().isBlank()) {
+            sections.add("Failure: " + task.failureMessage());
+        }
+        this.sendDiagnostic(sender, "Compute task", counters, sections);
+    }
+
+    private String formatComputeTaskLine(final ComputeTaskSnapshot task) {
+        return "#" + task.id()
+            + " " + task.type()
+            + " state=" + task.state()
+            + " priority=" + task.priority()
+            + " owner=" + task.owner().displayName()
+            + " queue=" + millisOrDash(task.queueTimeMs())
+            + " compute=" + millisOrDash(task.computeTimeMs())
+            + " description=\"" + task.description() + "\"";
+    }
+
+    private static String millisOrDash(final long millis) {
+        return millis < 0L ? "-" : millis + "ms";
+    }
+
+    private static String blankDash(final String value) {
+        return value == null || value.isBlank() ? "-" : value;
+    }
+
+    private void sendDiagnostic(final CommandSender sender, final String reportName, final Map<String, String> counters, final List<String> sections) {
+        final DiagnosticFormattingSnapshot snapshot = new DiagnosticFormattingSnapshot(ComputeGeneration.of(System.nanoTime()), reportName, counters, sections);
+        final ComputeTaskHandle<DiagnosticFormattingResult> handle = FuckTickComputeBroker.instance().submit(
+            ComputeTaskType.DIAGNOSTIC_FORMAT,
+            ComputePriority.LOW_DIAGNOSTICS,
+            ComputeTaskOwner.SERVER,
+            "diagnostic format " + reportName,
+            snapshot,
+            FuckTickComputeWorkloads::diagnosticFormat,
+            Runnable::run,
+            (context, result) -> ComputeApplyDecision.APPLIED
+        );
+        final DiagnosticFormattingResult result = handle.awaitResultOrFallback(250L, TimeUnit.MILLISECONDS, () -> FuckTickComputeWorkloads.diagnosticFormat(snapshot, new ComputeCancellationToken()));
+        for (final String line : result.formattedText().split("\\R")) {
+            sender.sendMessage(line);
+        }
+    }
+    // FuckTick End
+}
