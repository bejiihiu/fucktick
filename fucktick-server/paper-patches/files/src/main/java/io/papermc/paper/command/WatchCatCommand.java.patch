+        this.setAliases(List.of("meow"));
+        this.setPermission("bukkit.command.watchcat");
+        if (Bukkit.getServer() != null && Bukkit.getPluginManager().getPermission("bukkit.command.watchcat") == null) {
+            Bukkit.getPluginManager().addPermission(new Permission("bukkit.command.watchcat", PermissionDefault.OP));
+        }
+    }
