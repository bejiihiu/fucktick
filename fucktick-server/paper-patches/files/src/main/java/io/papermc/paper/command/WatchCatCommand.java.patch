+    private void sendQueue(final CommandSender sender, final PluginRuntimeSnapshot snapshot) {
+        this.sendDiagnostic(sender, "Plugin queue", Map.of(
+            "lifecycleQueued", Integer.toString(snapshot.lifecycleQueuedTasks()),
+            "callbackQueued", Integer.toString(snapshot.queuedTasks()),
+            "resultQueue", Integer.toString(snapshot.resultQueueSize()),
+            "blockedCallers", Integer.toString(snapshot.blockedCallers())
