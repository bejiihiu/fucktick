+    private void sendDump(final CommandSender sender, final PluginRuntimeSnapshot snapshot) {
+        final Map<String, String> counters = new LinkedHashMap<>();
+        counters.put("state", snapshot.state().name());
+        counters.put("threadId", Long.toString(snapshot.threadId()));
+        counters.put("queued", Integer.toString(snapshot.queuedTasks()));
+        counters.put("resultQueue", Integer.toString(snapshot.resultQueueSize()));
+        counters.put("lastTaskMs", Long.toString(snapshot.lastTaskDurationMs()));
+        counters.put("averageTaskMs", Long.toString(snapshot.averageTaskDurationMs()));
+        counters.put("blockedCallers", Integer.toString(snapshot.blockedCallers()));
+        final List<String> sections = new ArrayList<>();
+        sections.add("Plugin: " + snapshot.pluginName());
+        sections.add("Thread: " + snapshot.threadName());
+        sections.add("Running task: " + snapshot.runningTask());
+        sections.add("Last owner context: " + snapshot.lastOwnerContext());
+        final Throwable failure = PluginFUCKLOADER.instance().failure(snapshot.pluginName());
+        if (failure != null) {
+            final StringWriter writer = new StringWriter();
+            failure.printStackTrace(new PrintWriter(writer));
+            sections.add("Failure: " + writer);
+        }
+        this.sendDiagnostic(sender, "Plugin dump", counters, sections);
+    }
