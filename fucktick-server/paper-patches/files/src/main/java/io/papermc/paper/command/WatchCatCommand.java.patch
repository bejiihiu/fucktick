+    @Override
+    public boolean execute(final @NotNull CommandSender sender, final @NotNull String commandLabel, final @NotNull String[] args) {
+        if (!this.testPermission(sender)) {
+            return true;
+        }
+        // FuckTick Start - единая диагностика WatchCat
+        if (args.length == 0 || args[0].equalsIgnoreCase("status")) {
+            this.sendWatchCatStatus(sender);
+            return true;
+        }
+        if (args.length >= 1 && args[0].equalsIgnoreCase("targets")) {
+            this.sendWatchCatTargets(sender);
+            return true;
+        }
+        if (args.length >= 1 && args[0].equalsIgnoreCase("incidents")) {
+            this.sendWatchCatIncidents(sender);
+            return true;
+        }
+        if (args.length >= 1 && args[0].equalsIgnoreCase("threads")) {
+            this.sendWatchCatThreads(sender);
+            return true;
+        }
+        if (args.length >= 3 && args[0].equalsIgnoreCase("target")) {
+            this.sendWatchCatTarget(sender, args);
+            return true;
+        }
+        // FuckTick End
+        // FuckTick Start - диагностика compute broker
+        if (args.length >= 2 && args[0].equalsIgnoreCase("compute")) {
+            this.sendCompute(sender, args);
+            return true;
+        }
+        // FuckTick End
+        if (args.length >= 2 && args[0].equalsIgnoreCase("plugins") && args[1].equalsIgnoreCase("threads")) {
+            this.sendThreads(sender);
+            return true;
+        }
+        if (args.length >= 3 && args[0].equalsIgnoreCase("plugin")) {
+            final PluginRuntimeSnapshot snapshot = PluginFUCKLOADER.instance().snapshot(args[1]);
+            if (snapshot == null) {
+                sender.sendMessage("Unknown plugin runtime: " + args[1]);
+                return true;
+            }
+            switch (args[2].toLowerCase(java.util.Locale.ROOT)) {
+                case "dump" -> this.sendDump(sender, snapshot);
+                case "queue" -> this.sendQueue(sender, snapshot);
+                case "routing" -> this.sendRouting(sender, snapshot);
+                default -> sender.sendMessage("Usage: " + this.usageMessage);
+            }
+            return true;
+        }
+        sender.sendMessage("Usage: " + this.usageMessage);
+        return true;
+    }
