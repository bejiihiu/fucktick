+    @Override
+    public @NotNull List<String> tabComplete(final @NotNull CommandSender sender, final @NotNull String alias, final @NotNull String[] args) throws IllegalArgumentException {
+        if (args.length == 1) {
+            return matchingLast(args, List.of("status", "targets", "incidents", "threads", "target", "plugin", "compute"));
+        }
+        if (args.length == 2 && args[0].equalsIgnoreCase("target")) {
+            return matchingLast(args, WatchCat.instance().targetSnapshots().stream().map(WatchCatTargetSnapshot::id).toList());
+        }
+        if (args.length == 3 && args[0].equalsIgnoreCase("target")) {
+            return matchingLast(args, List.of("dump", "ping", "recover"));
+        }
+        if (args.length == 2 && args[0].equalsIgnoreCase("plugin")) {
+            return matchingLast(args, PluginFUCKLOADER.instance().snapshots().stream().map(PluginRuntimeSnapshot::pluginName).toList());
+        }
+        if (args.length == 3 && args[0].equalsIgnoreCase("plugin")) {
+            return matchingLast(args, List.of("dump", "queue", "routing"));
+        }
+        // FuckTick Start - tab-complete диагностики compute broker
+        if (args.length == 2 && args[0].equalsIgnoreCase("compute")) {
+            return matchingLast(args, List.of("status", "workers", "queue", "tasks", "task"));
+        }
+        if (args.length == 3 && args[0].equalsIgnoreCase("compute") && args[1].equalsIgnoreCase("task")) {
+            return matchingLast(args, FuckTickComputeBroker.instance().snapshot().tasks().stream().map(task -> Long.toString(task.id())).toList());
+        }
+        // FuckTick End
+        return List.of();
+    }
+
+    private static List<String> matchingLast(final String[] args, final List<String> values) {
+        final String token = args.length == 0 ? "" : args[args.length - 1].toLowerCase(java.util.Locale.ROOT);
+        return values.stream().filter(value -> value.toLowerCase(java.util.Locale.ROOT).startsWith(token)).toList();
+    }
