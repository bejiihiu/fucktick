+    // FuckTick Start - сериализация сохранения чанков через compute broker
+    private void submitComputeChunkSave(final FuckTickChunkSaveSnapshot snapshot, final Completable<CompoundTag> completable) {
+        final String worldName = snapshot.worldName();
+        final SerializableChunkData chunkData = snapshot.chunkData();
+        final ComputeTaskHandle<FuckTickChunkSaveResult> handle = FuckTickComputeBroker.instance().submit(
+            ComputeTaskType.CHUNK_SAVE_SERIALIZE,
+            ComputePriority.CRITICAL_SAVE,
+            new ComputeTaskOwner(worldName, null),
+            "serialize chunk " + snapshot.chunkX() + "," + snapshot.chunkZ() + " in world " + worldName,
+            snapshot,
+            (final FuckTickChunkSaveSnapshot taskSnapshot, final io.papermc.paper.fucktick.compute.ComputeCancellationToken token) -> {
+                if (token.isCancelled()) {
+                    throw new ComputeTaskCancelledException(token.reason());
+                }
+                return new FuckTickChunkSaveResult(taskSnapshot.generation(), taskSnapshot.chunkData().write());
+            },
+            Runnable::run,
+            (context, result) -> ComputeApplyDecision.APPLIED
+        );
+        handle.result().whenComplete((final FuckTickChunkSaveResult result, final Throwable throwable) -> {
+            if (throwable == null) {
+                completable.complete(result.data());
+                return;
+            }
+            LOGGER.warn("FuckTick compute chunk serialization failed; falling back to scheduler serialization for chunk ({},{}) in world '{}'", snapshot.chunkX(), snapshot.chunkZ(), worldName, throwable);
+            this.completeChunkSaveFallback(chunkData, completable);
+        });
+    }
+
+    private void completeChunkSaveFallback(final SerializableChunkData chunkData, final Completable<CompoundTag> completable) {
+        try {
+            completable.complete(chunkData.write());
+        } catch (final Throwable thr) {
+            LOGGER.error("Failed to save chunk data (" + this.chunkX + "," + this.chunkZ + ") in world '" + WorldUtil.getWorldName(this.world) + "'", thr);
+            completable.completeExceptionally(thr);
+        }
+    }
+
+    private record FuckTickChunkSaveSnapshot(
+        ComputeGeneration generation,
+        String worldName,
+        int chunkX,
+        int chunkZ,
+        SerializableChunkData chunkData
+    ) implements ComputeSnapshot {}
+
+    private record FuckTickChunkSaveResult(ComputeGeneration generation, CompoundTag data) implements ComputeResult {}
+    // FuckTick End
