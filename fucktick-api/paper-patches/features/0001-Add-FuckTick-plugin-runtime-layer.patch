@@ -0,0 +1,40 @@
+package io.papermc.paper.fucktick.plugin;
+
+import org.bukkit.Bukkit;
+import org.bukkit.Location;
+import org.bukkit.entity.Entity;
+
+public final class FuckTickThreadChecks {
+
+    private FuckTickThreadChecks() {
+    }
+
+    public static boolean isPluginThread() {
+        return FuckTickPluginContext.currentRuntime() != null;
+    }
+
+    public static boolean isGlobalThread() {
+        try {
+            return Bukkit.getServer() != null && Bukkit.isGlobalTickThread();
+        } catch (final Throwable ignored) {
+            return false;
+        }
+    }
+
+    public static boolean isRegionThread() {
+        final String threadName = Thread.currentThread().getName();
+        return threadName.contains("Region") || threadName.contains("region");
+    }
+
+    public static void requireRegionThread(final Location location) {
+        if (location == null || !Bukkit.isOwnedByCurrentRegion(location)) {
+            throw new IllegalStateException("World data must be accessed from the owning region thread. Use RegionScheduler to enter the correct owner context.");
+        }
+    }
+
+    public static void requireEntityThread(final Entity entity) {
+        if (entity == null || !Bukkit.isOwnedByCurrentRegion(entity)) {
+            throw new IllegalStateException("Entity data must be accessed from the owning entity or region thread. Use EntityScheduler to enter the correct owner context.");
+        }
+    }
+}
diff --git a/src/main/java/io/papermc/paper/fucktick/plugin/PluginFUCKLOADER.java b/src/main/java/io/papermc/paper/fucktick/plugin/PluginFUCKLOADER.java
new file mode 100644
index 0000000000000000000000000000000000000000..744e97d7b29b0ad874d998ccd270e8c817af1329
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/plugin/PluginFUCKLOADER.java
@@ -0,0 +1,204 @@
+package io.papermc.paper.fucktick.plugin;
+
+import io.papermc.paper.plugin.configuration.PluginMeta;
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+import java.util.Locale;
+import java.util.Map;
+import java.util.concurrent.Callable;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ConcurrentHashMap;
+import java.util.concurrent.ExecutorService;
+import java.util.concurrent.Executors;
+import java.util.concurrent.Future;
+import java.util.concurrent.TimeUnit;
+import java.util.concurrent.atomic.AtomicReference;
+import java.util.logging.Level;
+import org.bukkit.Bukkit;
+import org.bukkit.plugin.Plugin;
+
+public final class PluginFUCKLOADER {
+
+    private static final PluginFUCKLOADER INSTANCE = new PluginFUCKLOADER();
+
+    private final Map<String, PluginRuntime> runtimes = new ConcurrentHashMap<>();
+    private final AtomicReference<Thread> managementThread = new AtomicReference<>();
+    private final ExecutorService managementExecutor = Executors.newSingleThreadExecutor(runnable -> {
+        final Thread thread = new Thread(runnable, "PluginFUCKLOADER");
+        thread.setDaemon(false);
+        INSTANCE.managementThread.set(thread);
+        return thread;
+    });
+
+    private PluginFUCKLOADER() {
+    }
+
+    public static PluginFUCKLOADER instance() {
+        return INSTANCE;
+    }
+
+    public PluginRuntimeSnapshot registerPlugin(final Plugin plugin) {
+        return this.runtime(plugin).snapshot();
+    }
+
+    public void loadPlugin(final Plugin plugin, final Runnable loadAction) throws Throwable {
+        final PluginRuntime runtime = this.runtime(plugin);
+        runtime.markLoading();
+        try {
+            this.callOnManagement(() -> {
+                try (FuckTickPluginContext.Scope ignored = FuckTickPluginContext.enterManagement()) {
+                    loadAction.run();
+                    return null;
+                }
+            });
+            runtime.markLoaded();
+        } catch (final Throwable throwable) {
+            runtime.markFailed(throwable);
+            throw throwable;
+        }
+    }
+
+    public void enablePlugin(final Plugin plugin, final Runnable enableAction) throws Throwable {
+        final PluginRuntime runtime = this.runtime(plugin);
+        runtime.start();
+        runtime.markEnabling();
+        try {
+            runtime.callLifecycle("enable:" + plugin.getName(), () -> {
+                enableAction.run();
+                return null;
+            }, PluginRuntimeSettings.maxPluginCallbackTimeMs());
+            runtime.markEnabled();
+            this.logCompatibilityReport(plugin, runtime);
+        } catch (final Throwable throwable) {
+            runtime.markFailed(throwable);
+            throw throwable;
+        }
+    }
+
+    public void disablePlugin(final Plugin plugin, final Runnable disableAction) throws Throwable {
+        final PluginRuntime runtime = this.runtimes.get(key(plugin.getName()));
+        if (runtime == null) {
+            disableAction.run();
+            return;
+        }
+        runtime.markDraining();
+        runtime.markDisabling();
+        try {
+            runtime.callLifecycle("disable:" + plugin.getName(), () -> {
+                disableAction.run();
+                return null;
+            }, PluginRuntimeSettings.maxDisableDrainTimeMs());
+            runtime.markDisabled();
+        } catch (final Throwable throwable) {
+            runtime.markFailed(throwable);
+            throw throwable;
+        } finally {
+            runtime.stopAndJoin(PluginRuntimeSettings.maxDisableDrainTimeMs());
+        }
+    }
+
+    public CompletableFuture<Void> executePluginTask(final Plugin plugin, final String label, final Runnable runnable) {
+        final PluginRuntime runtime = this.runtime(plugin);
+        runtime.start();
+        return runtime.executeCallback(label, runnable::run);
+    }
+
+    public <T> T callPluginBlocking(final Plugin plugin, final String label, final Callable<T> callable, final long timeoutMs) throws Throwable {
+        final PluginRuntime runtime = this.runtime(plugin);
+        runtime.start();
+        return runtime.callCallback(label, callable::call, timeoutMs);
+    }
+
+    public List<PluginRuntimeSnapshot> snapshots() {
+        return this.runtimes.values().stream()
+            .map(PluginRuntime::snapshot)
+            .sorted(Comparator.comparing(PluginRuntimeSnapshot::pluginName, String.CASE_INSENSITIVE_ORDER))
+            .toList();
+    }
+
+    public PluginRuntimeSnapshot snapshot(final String pluginName) {
+        final PluginRuntime runtime = this.runtimes.get(key(pluginName));
+        return runtime == null ? null : runtime.snapshot();
+    }
+
+    public Throwable failure(final String pluginName) {
+        final PluginRuntime runtime = this.runtimes.get(key(pluginName));
+        return runtime == null ? null : runtime.failure();
+    }
+
+    public String loggerContext() {
+        final String contextName = FuckTickPluginContext.currentContextName();
+        if (contextName != null) {
+            return contextName;
+        }
+        if (Thread.currentThread() == this.managementThread.get()) {
+            return "PluginFUCKLOADER";
+        }
+        if (FuckTickThreadChecks.isGlobalThread()) {
+            return "global-owner";
+        }
+        if (FuckTickThreadChecks.isRegionThread()) {
+            return "region-owner";
+        }
+        return "async";
+    }
+
+    public String formatLoggerMessage(final PluginMeta meta, final String message) {
+        final String pluginName = meta.getName();
+        final long threadId = Thread.currentThread().threadId();
+        return "[plugin:" + pluginName + "] [tid:" + threadId + "] [ctx:" + this.loggerContext() + "] " + (message == null ? "" : message);
+    }
+
+    public void shutdown() {
+        final List<PluginRuntime> copy = new ArrayList<>(this.runtimes.values());
+        for (final PluginRuntime runtime : copy) {
+            runtime.stopAndJoin(PluginRuntimeSettings.maxDisableDrainTimeMs());
+        }
+        this.managementExecutor.shutdownNow();
+        try {
+            this.managementExecutor.awaitTermination(5L, TimeUnit.SECONDS);
+        } catch (final InterruptedException interruptedException) {
+            Thread.currentThread().interrupt();
+        }
+    }
+
+    private PluginRuntime runtime(final Plugin plugin) {
+        return this.runtimes.computeIfAbsent(key(plugin.getName()), ignored -> new PluginRuntime(plugin));
+    }
+
+    private <T> T callOnManagement(final Callable<T> callable) throws Throwable {
+        if (Thread.currentThread() == this.managementThread.get()) {
+            return callable.call();
+        }
+        final Future<T> future = this.managementExecutor.submit(callable);
+        try {
+            return future.get(PluginRuntimeSettings.maxPluginCallbackTimeMs(), TimeUnit.MILLISECONDS);
+        } catch (final java.util.concurrent.ExecutionException executionException) {
+            throw executionException.getCause();
+        }
+    }
+
+    private void logCompatibilityReport(final Plugin plugin, final PluginRuntime runtime) {
+        final boolean foliaSupported = plugin.getPluginMeta().isFoliaSupported();
+        final PluginRuntimeSnapshot snapshot = runtime.snapshot();
+        plugin.getLogger().info(
+            "Plugin compatibility report:"
+                + " plugin=" + plugin.getName()
+                + " folia-supported=" + foliaSupported
+                + " uses-plugin-thread=true"
+                + " commands=offloaded"
+                + " tab-complete=offloaded"
+                + " asyncScheduler=plugin-thread"
+                + " regionScheduler=owner-thread"
+                + " entityScheduler=owner-thread"
+                + " globalScheduler=owner-thread"
+                + " state=" + snapshot.state()
+                + " threadId=" + snapshot.threadId()
+        );
+    }
+
+    private static String key(final String pluginName) {
+        return pluginName.toLowerCase(Locale.ROOT);
+    }
+}
diff --git a/src/main/java/io/papermc/paper/fucktick/plugin/PluginRuntime.java b/src/main/java/io/papermc/paper/fucktick/plugin/PluginRuntime.java
new file mode 100644
index 0000000000000000000000000000000000000000..48640bcb03866241aa863c16062197b02937fd30
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/plugin/PluginRuntime.java
@@ -0,0 +1,296 @@
+package io.papermc.paper.fucktick.plugin;
+
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Locale;
+import java.util.concurrent.BlockingQueue;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ExecutionException;
+import java.util.concurrent.LinkedBlockingQueue;
+import java.util.concurrent.TimeUnit;
+import java.util.concurrent.TimeoutException;
+import java.util.concurrent.atomic.AtomicInteger;
+import java.util.concurrent.atomic.AtomicLong;
+import java.util.concurrent.atomic.AtomicReference;
+import java.util.logging.Level;
+import org.bukkit.plugin.Plugin;
+
+final class PluginRuntime {
+
+    private final Plugin plugin;
+    private final BlockingQueue<PluginTask<?>> lifecycleQueue = new LinkedBlockingQueue<>();
+    private final BlockingQueue<PluginTask<?>> callbackQueue = new LinkedBlockingQueue<>(PluginRuntimeSettings.maxQueuedTasksPerPlugin());
+    private final AtomicReference<PluginRuntimeState> state = new AtomicReference<>(PluginRuntimeState.CREATED);
+    private final AtomicInteger blockedCallers = new AtomicInteger();
+    private final AtomicInteger resultQueueSize = new AtomicInteger();
+    private final AtomicLong completedTasks = new AtomicLong();
+    private final AtomicLong totalTaskDurationNs = new AtomicLong();
+
+    private volatile Thread thread;
+    private volatile boolean stopRequested;
+    private volatile String runningTask;
+    private volatile long runningTaskStartNs;
+    private volatile long lastTaskDurationNs;
+    private volatile String lastOwnerContext = "unknown";
+    private volatile Throwable failure;
+
+    PluginRuntime(final Plugin plugin) {
+        this.plugin = plugin;
+    }
+
+    Plugin plugin() {
+        return this.plugin;
+    }
+
+    PluginRuntimeState state() {
+        return this.state.get();
+    }
+
+    synchronized void start() {
+        if (this.thread != null) {
+            return;
+        }
+        final Thread created = new Thread(this::runLoop, "FuckTick Plugin Thread - " + this.plugin.getName());
+        created.setDaemon(false);
+        created.setUncaughtExceptionHandler((thread, throwable) -> this.fail("uncaught-exception", throwable));
+        this.thread = created;
+        created.start();
+    }
+
+    void markLoading() {
+        this.state.set(PluginRuntimeState.LOADING);
+    }
+
+    void markLoaded() {
+        this.state.set(PluginRuntimeState.LOADED);
+    }
+
+    void markEnabling() {
+        this.state.set(PluginRuntimeState.ENABLING);
+    }
+
+    void markEnabled() {
+        this.state.set(PluginRuntimeState.ENABLED);
+    }
+
+    void markDraining() {
+        this.state.set(PluginRuntimeState.DRAINING);
+        this.cancelQueuedCallbacks("plugin runtime is draining");
+    }
+
+    void markDisabling() {
+        this.state.set(PluginRuntimeState.DISABLING);
+    }
+
+    void markDisabled() {
+        this.state.set(PluginRuntimeState.DISABLED);
+    }
+
+    void markTerminated() {
+        this.state.set(PluginRuntimeState.TERMINATED);
+    }
+
+    void markFailed(final Throwable throwable) {
+        this.failure = throwable;
+        this.state.set(PluginRuntimeState.FAILED);
+        this.cancelQueuedCallbacks("plugin runtime failed");
+    }
+
+    <T> T callLifecycle(final String label, final ThrowingSupplier<T> supplier, final long timeoutMs) throws Throwable {
+        return this.callBlocking(label, true, supplier, timeoutMs);
+    }
+
+    <T> T callCallback(final String label, final ThrowingSupplier<T> supplier, final long timeoutMs) throws Throwable {
+        return this.callBlocking(label, false, supplier, timeoutMs);
+    }
+
+    CompletableFuture<Void> executeCallback(final String label, final ThrowingRunnable runnable) {
+        final CompletableFuture<Void> future = new CompletableFuture<>();
+        final PluginRuntimeState currentState = this.state.get();
+        if (currentState != PluginRuntimeState.ENABLING && currentState != PluginRuntimeState.ENABLED) {
+            future.completeExceptionally(new IllegalStateException("Plugin " + this.plugin.getName() + " is not accepting callbacks in state " + currentState));
+            return future;
+        }
+        final PluginTask<Void> task = new PluginTask<>(label, false, () -> {
+            runnable.run();
+            return null;
+        }, future);
+        if (!this.callbackQueue.offer(task)) {
+            final String message = "Plugin " + this.plugin.getName() + " exceeded max queued tasks. queued=" + this.callbackQueue.size() + " limit=" + PluginRuntimeSettings.maxQueuedTasksPerPlugin();
+            this.plugin.getLogger().warning(message);
+            future.completeExceptionally(new IllegalStateException(message));
+        }
+        return future;
+    }
+
+    void stopAndJoin(final long timeoutMs) {
+        this.stopRequested = true;
+        final Thread currentThread = this.thread;
+        if (currentThread == null) {
+            this.markTerminated();
+            return;
+        }
+        currentThread.interrupt();
+        try {
+            currentThread.join(Math.max(1L, timeoutMs));
+        } catch (final InterruptedException interruptedException) {
+            Thread.currentThread().interrupt();
+        }
+        if (currentThread.isAlive()) {
+            this.plugin.getLogger().warning("Plugin thread did not stop in time: plugin=" + this.plugin.getName() + " thread=" + currentThread.getName());
+        } else {
+            this.markTerminated();
+        }
+    }
+
+    PluginRuntimeSnapshot snapshot() {
+        final Thread currentThread = this.thread;
+        final long now = System.nanoTime();
+        final long runningDuration = this.runningTaskStartNs == 0L ? 0L : TimeUnit.NANOSECONDS.toMillis(now - this.runningTaskStartNs);
+        final long completed = this.completedTasks.get();
+        final long average = completed == 0L ? 0L : TimeUnit.NANOSECONDS.toMillis(this.totalTaskDurationNs.get() / completed);
+        return new PluginRuntimeSnapshot(
+            this.plugin.getName(),
+            this.state.get(),
+            currentThread == null ? "" : currentThread.getName(),
+            currentThread == null ? -1L : currentThread.threadId(),
+            this.callbackQueue.size(),
+            this.lifecycleQueue.size(),
+            this.resultQueueSize.get(),
+            this.runningTask == null ? "" : this.runningTask,
+            runningDuration,
+            TimeUnit.NANOSECONDS.toMillis(this.lastTaskDurationNs),
+            average,
+            this.blockedCallers.get(),
+            this.lastOwnerContext
+        );
+    }
+
+    Throwable failure() {
+        return this.failure;
+    }
+
+    private <T> T callBlocking(final String label, final boolean lifecycle, final ThrowingSupplier<T> supplier, final long timeoutMs) throws Throwable {
+        if (Thread.currentThread() == this.thread) {
+            return supplier.get();
+        }
+        final CompletableFuture<T> future = new CompletableFuture<>();
+        final PluginTask<T> task = new PluginTask<>(label, lifecycle, supplier, future);
+        if (lifecycle) {
+            this.lifecycleQueue.offer(task);
+        } else if (!this.callbackQueue.offer(task)) {
+            throw new IllegalStateException("Plugin " + this.plugin.getName() + " exceeded max queued tasks. queued=" + this.callbackQueue.size() + " limit=" + PluginRuntimeSettings.maxQueuedTasksPerPlugin());
+        }
+
+        this.blockedCallers.incrementAndGet();
+        this.resultQueueSize.incrementAndGet();
+        this.lastOwnerContext = Thread.currentThread().getName();
+        try {
+            return future.get(Math.max(1L, timeoutMs), TimeUnit.MILLISECONDS);
+        } catch (final TimeoutException timeoutException) {
+            future.cancel(false);
+            this.logTimeout(label, timeoutMs);
+            throw timeoutException;
+        } catch (final ExecutionException executionException) {
+            throw executionException.getCause();
+        } finally {
+            this.blockedCallers.decrementAndGet();
+            this.resultQueueSize.decrementAndGet();
+        }
+    }
+
+    private void runLoop() {
+        while (true) {
+            if (this.stopRequested && this.lifecycleQueue.isEmpty() && this.callbackQueue.isEmpty()) {
+                return;
+            }
+            try {
+                final PluginTask<?> task = this.takeTask();
+                if (task == null) {
+                    continue;
+                }
+                this.executeTask(task);
+            } catch (final InterruptedException ignored) {
+            } catch (final Throwable throwable) {
+                this.fail("plugin-thread", throwable);
+            }
+        }
+    }
+
+    private PluginTask<?> takeTask() throws InterruptedException {
+        final PluginTask<?> lifecycleTask = this.lifecycleQueue.poll();
+        if (lifecycleTask != null) {
+            return lifecycleTask;
+        }
+        final PluginTask<?> callbackTask = this.callbackQueue.poll(250L, TimeUnit.MILLISECONDS);
+        if (callbackTask != null) {
+            return callbackTask;
+        }
+        return this.lifecycleQueue.poll();
+    }
+
+    private <T> void executeTask(final PluginTask<T> task) {
+        if (task.future.isCancelled()) {
+            return;
+        }
+        this.runningTask = task.label;
+        this.runningTaskStartNs = System.nanoTime();
+        try (FuckTickPluginContext.Scope ignored = FuckTickPluginContext.enter(this, task.lifecycle ? "plugin-lifecycle" : "plugin-thread")) {
+            final T result = task.supplier.get();
+            task.future.complete(result);
+        } catch (final Throwable throwable) {
+            task.future.completeExceptionally(throwable);
+        } finally {
+            final long duration = System.nanoTime() - this.runningTaskStartNs;
+            this.lastTaskDurationNs = duration;
+            this.totalTaskDurationNs.addAndGet(duration);
+            this.completedTasks.incrementAndGet();
+            this.runningTask = null;
+            this.runningTaskStartNs = 0L;
+        }
+    }
+
+    private void cancelQueuedCallbacks(final String reason) {
+        final List<PluginTask<?>> drained = new ArrayList<>();
+        this.callbackQueue.drainTo(drained);
+        final IllegalStateException exception = new IllegalStateException(reason);
+        for (final PluginTask<?> task : drained) {
+            task.future.completeExceptionally(exception);
+        }
+    }
+
+    private void fail(final String label, final Throwable throwable) {
+        this.failure = throwable;
+        this.state.set(PluginRuntimeState.FAILED);
+        this.plugin.getLogger().log(Level.SEVERE, "Plugin " + this.plugin.getName() + " crashed on its plugin-owned thread. label=" + label, throwable);
+        this.cancelQueuedCallbacks("plugin runtime failed");
+    }
+
+    private void logTimeout(final String label, final long timeoutMs) {
+        final Thread pluginThread = this.thread;
+        final String pluginThreadName = pluginThread == null ? "<not-started>" : pluginThread.getName();
+        final long pluginThreadId = pluginThread == null ? -1L : pluginThread.threadId();
+        this.plugin.getLogger().warning(
+            "Plugin callback timeout: plugin=" + this.plugin.getName()
+                + " callback=" + label
+                + " callerThread=" + Thread.currentThread().getName()
+                + " pluginThread=" + pluginThreadName
+                + " pluginThreadId=" + pluginThreadId
+                + " waited=" + timeoutMs + "ms"
+                + " possibleDeadlock=true"
+        );
+    }
+
+    @FunctionalInterface
+    interface ThrowingRunnable {
