@@ -0,0 +1,64 @@
+package io.papermc.paper.fucktick.plugin;
+
+import org.bukkit.plugin.Plugin;
+
+public final class FuckTickPluginContext {
+
+    private static final ThreadLocal<Context> CURRENT = new ThreadLocal<>();
+
+    private FuckTickPluginContext() {
+    }
+
+    static Scope enter(final PluginRuntime runtime, final String contextName) {
+        final Context previous = CURRENT.get();
+        CURRENT.set(new Context(runtime, contextName));
+        return () -> {
+            if (previous == null) {
+                CURRENT.remove();
+            } else {
+                CURRENT.set(previous);
+            }
+        };
+    }
+
+    static Scope enterManagement() {
+        final Context previous = CURRENT.get();
+        CURRENT.set(new Context(null, "PluginFUCKLOADER"));
+        return () -> {
+            if (previous == null) {
+                CURRENT.remove();
+            } else {
+                CURRENT.set(previous);
+            }
+        };
+    }
+
+    public static Plugin currentPlugin() {
+        final Context context = CURRENT.get();
+        return context == null || context.runtime == null ? null : context.runtime.plugin();
+    }
+
+    public static PluginRuntimeState currentState() {
+        final Context context = CURRENT.get();
+        return context == null || context.runtime == null ? null : context.runtime.state();
+    }
+
+    public static String currentContextName() {
+        final Context context = CURRENT.get();
+        return context == null ? null : context.contextName;
+    }
+
+    static PluginRuntime currentRuntime() {
+        final Context context = CURRENT.get();
+        return context == null ? null : context.runtime;
+    }
+
+    @FunctionalInterface
+    interface Scope extends AutoCloseable {
+        @Override
+        void close();
+    }
+
+    private record Context(PluginRuntime runtime, String contextName) {
+    }
+}
