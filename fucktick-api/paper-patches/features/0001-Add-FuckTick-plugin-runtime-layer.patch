+++ b/src/test/java/io/papermc/paper/fucktick/plugin/PluginFUCKLOADERTest.java
@@ -0,0 +1,82 @@
+package io.papermc.paper.fucktick.plugin;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+import static org.junit.jupiter.api.Assertions.assertNotEquals;
+import static org.junit.jupiter.api.Assertions.assertTrue;
+import static org.mockito.Mockito.mock;
+import static org.mockito.Mockito.when;
+
+import io.papermc.paper.plugin.configuration.PluginMeta;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.TimeUnit;
+import java.util.concurrent.atomic.AtomicInteger;
+import java.util.concurrent.atomic.AtomicReference;
+import java.util.logging.Logger;
+import org.bukkit.plugin.Plugin;
+import org.junit.jupiter.api.Test;
+
+class PluginFUCKLOADERTest {
+
+    @Test
+    void lifecycleAndCallbacksUseDedicatedThreads() throws Throwable {
+        final PluginFUCKLOADER loader = PluginFUCKLOADER.instance();
+        final Plugin first = plugin("FirstRuntimePlugin");
+        final Plugin second = plugin("SecondRuntimePlugin");
+        final AtomicReference<String> loadThread = new AtomicReference<>();
+        final AtomicReference<String> firstEnableThread = new AtomicReference<>();
+        final AtomicReference<String> secondEnableThread = new AtomicReference<>();
+        final AtomicReference<String> disableThread = new AtomicReference<>();
+
+        loader.loadPlugin(first, () -> loadThread.set(Thread.currentThread().getName()));
+        loader.enablePlugin(first, () -> firstEnableThread.set(Thread.currentThread().getName()));
+        loader.enablePlugin(second, () -> secondEnableThread.set(Thread.currentThread().getName()));
+
+        assertEquals("PluginFUCKLOADER", loadThread.get());
+        assertTrue(firstEnableThread.get().startsWith("FuckTick Plugin Thread - FirstRuntimePlugin"));
+        assertTrue(secondEnableThread.get().startsWith("FuckTick Plugin Thread - SecondRuntimePlugin"));
+        assertNotEquals(firstEnableThread.get(), secondEnableThread.get());
+
+        final String commandThread = loader.callPluginBlocking(first, "command:/runtime-test", () -> Thread.currentThread().getName(), 5_000L);
+        assertEquals(firstEnableThread.get(), commandThread);
+
+        final AtomicInteger activeCallbacks = new AtomicInteger();
+        final AtomicInteger maxActiveCallbacks = new AtomicInteger();
+        final CompletableFuture<Void> firstTask = loader.executePluginTask(first, "test:first", () -> {
+            final int active = activeCallbacks.incrementAndGet();
+            maxActiveCallbacks.accumulateAndGet(active, Math::max);
+            try {
+                Thread.sleep(50L);
+            } catch (final InterruptedException interruptedException) {
+                Thread.currentThread().interrupt();
+            }
+            activeCallbacks.decrementAndGet();
+        });
+        final CompletableFuture<Void> secondTask = loader.executePluginTask(first, "test:second", () -> {
+            final int active = activeCallbacks.incrementAndGet();
+            maxActiveCallbacks.accumulateAndGet(active, Math::max);
+            activeCallbacks.decrementAndGet();
+        });
+
+        firstTask.get(5L, TimeUnit.SECONDS);
+        secondTask.get(5L, TimeUnit.SECONDS);
+        assertEquals(1, maxActiveCallbacks.get());
+
+        loader.disablePlugin(first, () -> disableThread.set(Thread.currentThread().getName()));
+        loader.disablePlugin(second, () -> {});
+        assertEquals(firstEnableThread.get(), disableThread.get());
+        assertEquals(PluginRuntimeState.TERMINATED, loader.snapshot("FirstRuntimePlugin").state());
+        loader.shutdown();
+    }
+
+    private static Plugin plugin(final String name) {
+        final Plugin plugin = mock(Plugin.class);
+        final PluginMeta meta = mock(PluginMeta.class);
+        when(meta.getName()).thenReturn(name);
+        when(meta.getDisplayName()).thenReturn(name + " v1.0");
+        when(meta.isFoliaSupported()).thenReturn(true);
+        when(plugin.getName()).thenReturn(name);
+        when(plugin.getPluginMeta()).thenReturn(meta);
+        when(plugin.getLogger()).thenReturn(Logger.getLogger("test." + name + "." + System.nanoTime()));
+        return plugin;
+    }
+}
