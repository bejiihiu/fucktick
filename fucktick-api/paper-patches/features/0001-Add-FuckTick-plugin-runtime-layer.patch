+package io.papermc.paper.fucktick.plugin.routing;
+
+import java.util.ArrayList;
+import java.util.List;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.Event;
+
+public final class EventRoutingRegistry {
+
+    private static final List<EventContextExtractor<? extends Event>> EXTRACTORS = new ArrayList<>();
+    private static volatile RoutingPolicy routingPolicy = ConservativeRoutingPolicy.INSTANCE;
+
+    static {
+        register(new GeneratedFuckTickEventRoutingTable());
+    }
+
+    private EventRoutingRegistry() {
+    }
+
+    public static void register(final EventContextExtractor<? extends Event> extractor) {
+        EXTRACTORS.add(extractor);
+    }
+
+    public static RoutingPlan plan(final Event event) {
+        final RoutingMetadata metadata = metadata(event);
+        return routingPolicy.plan(event, metadata);
+    }
+
+    public static RoutingMetadata metadata(final Event event) {
+        for (final EventContextExtractor<? extends Event> extractor : EXTRACTORS) {
+            if (extractor.supports(event.getClass())) {
+                return extract(extractor, event);
+            }
+        }
+        return RoutingMetadata.unknown(event instanceof Cancellable);
+    }
+
+    public static void policy(final RoutingPolicy policy) {
+        routingPolicy = policy;
+    }
+
+    @SuppressWarnings({"unchecked", "rawtypes"})
+    private static RoutingMetadata extract(final EventContextExtractor extractor, final Event event) {
+        return extractor.extract(event);
+    }
+}
diff --git a/src/main/java/io/papermc/paper/fucktick/plugin/routing/GeneratedFuckTickEventRoutingTable.java b/src/main/java/io/papermc/paper/fucktick/plugin/routing/GeneratedFuckTickEventRoutingTable.java
new file mode 100644
index 0000000000000000000000000000000000000000..f8db83e769210c30c1582771992707c7c0c67c68
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/plugin/routing/GeneratedFuckTickEventRoutingTable.java
@@ -0,0 +1,54 @@
+package io.papermc.paper.fucktick.plugin.routing;
+
+import org.bukkit.Location;
+import org.bukkit.entity.Entity;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.Event;
+
+public final class GeneratedFuckTickEventRoutingTable implements EventContextExtractor<Event> {
+
+    @Override
+    public boolean supports(final Class<? extends Event> eventClass) {
+        return true;
+    }
+
+    @Override
+    public RoutingMetadata extract(final Event event) {
+        final String name = event.getClass().getName();
+        final boolean cancellable = event instanceof Cancellable;
+        if (event.isAsynchronous() && (name.contains(".server.") || name.contains(".player.Async"))) {
+            return new RoutingMetadata(EventRisk.PLUGIN_LOCAL, EventOwnership.NONE, false, cancellable, false, false, name.contains(".player."), null, null, null, "async plugin callback");
+        }
+        if (name.contains(".block.")) {
+            return new RoutingMetadata(EventRisk.OWNER_BOUND, EventOwnership.REGION, false, cancellable, true, false, false, null, null, extractLocation(event), "block event");
+        }
+        if (name.contains(".entity.")) {
+            return new RoutingMetadata(EventRisk.OWNER_BOUND, EventOwnership.ENTITY, false, cancellable, false, true, false, null, extractEntity(event), null, "entity event");
+        }
+        if (name.contains(".world.") || name.contains(".chunk.")) {
+            return new RoutingMetadata(EventRisk.OWNER_BOUND, EventOwnership.REGION, false, cancellable, true, false, false, null, null, extractLocation(event), "world or chunk event");
+        }
+        if (name.contains(".server.")) {
+            return new RoutingMetadata(EventRisk.GLOBAL_SAFE, EventOwnership.GLOBAL, false, cancellable, false, false, false, null, null, null, "server event");
+        }
+        return RoutingMetadata.unknown(cancellable);
+    }
+
+    private static Location extractLocation(final Event event) {
+        try {
+            final Object value = event.getClass().getMethod("getLocation").invoke(event);
+            return value instanceof Location location ? location : null;
+        } catch (final ReflectiveOperationException ignored) {
+            return null;
+        }
+    }
+
+    private static Entity extractEntity(final Event event) {
+        try {
+            final Object value = event.getClass().getMethod("getEntity").invoke(event);
+            return value instanceof Entity entity ? entity : null;
+        } catch (final ReflectiveOperationException ignored) {
+            return null;
+        }
+    }
+}
