+package io.papermc.paper.fucktick.plugin;
+
+public final class PluginRuntimeSettings {
+
+    private PluginRuntimeSettings() {
+    }
+
+    public static int maxQueuedTasksPerPlugin() {
+        return readInt("fucktick.plugin.maxQueuedTasksPerPlugin", 10_000);
+    }
+
+    public static int maxQueuedResultsPerPlugin() {
+        return readInt("fucktick.plugin.maxQueuedResultsPerPlugin", 1_024);
+    }
+
+    public static long maxBlockingCommandTimeMs() {
+        return readLong("fucktick.plugin.maxBlockingCommandTimeMs", 5_000L);
+    }
+
+    public static long maxBlockingTabCompleteTimeMs() {
+        return readLong("fucktick.plugin.maxBlockingTabCompleteTimeMs", 5_000L);
+    }
+
+    public static long maxDisableDrainTimeMs() {
+        return readLong("fucktick.plugin.maxDisableDrainTimeMs", 10_000L);
+    }
+
+    public static long maxPluginCallbackTimeMs() {
+        return readLong("fucktick.plugin.maxPluginCallbackTimeMs", 10_000L);
+    }
+
+    private static int readInt(final String key, final int fallback) {
+        final String value = System.getProperty(key);
+        if (value == null) {
+            return fallback;
+        }
+        try {
+            return Math.max(1, Integer.parseInt(value));
+        } catch (final NumberFormatException ignored) {
+            return fallback;
+        }
+    }
+
+    private static long readLong(final String key, final long fallback) {
+        final String value = System.getProperty(key);
+        if (value == null) {
+            return fallback;
+        }
+        try {
+            return Math.max(1L, Long.parseLong(value));
+        } catch (final NumberFormatException ignored) {
+            return fallback;
+        }
+    }
+}
