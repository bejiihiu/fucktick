+package io.papermc.paper.fucktick.plugin.routing;
+
+import org.bukkit.event.Event;
+
+public final class ConservativeRoutingPolicy implements RoutingPolicy {
+
+    public static final ConservativeRoutingPolicy INSTANCE = new ConservativeRoutingPolicy();
+
+    private ConservativeRoutingPolicy() {
+    }
+
+    @Override
+    public RoutingPlan plan(final Event event, final RoutingMetadata metadata) {
+        return switch (metadata.risk()) {
+            case PLUGIN_LOCAL -> event.isAsynchronous()
+                ? new RoutingPlan(RoutingPlanType.ASYNC_PLUGIN, metadata)
+                : RoutingPlan.ownerOnly(metadata);
+            case GLOBAL_SAFE, RESULT_REQUIRED, PLUGIN_COMPUTE_THEN_OWNER_APPLY, OWNER_BOUND, UNKNOWN_OWNER_BOUND -> RoutingPlan.ownerOnly(metadata);
+        };
+    }
+}
