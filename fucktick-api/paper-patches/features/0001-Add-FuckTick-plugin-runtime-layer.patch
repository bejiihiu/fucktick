+package io.papermc.paper.fucktick.plugin.effect;
+
+import java.util.ArrayList;
+import java.util.List;
+
+public final class PluginEffectApplierRegistry {
+
+    private static final List<PluginEffectApplier<? extends PluginEffect>> APPLIERS = new ArrayList<>();
+
+    static {
+        register(new SendMessageEffectApplier());
+        register(new RunRegionEffectApplier());
+        register(new RunGlobalEffectApplier());
+        register(new RunEntityEffectApplier());
+        register(new CancelEventEffectApplier());
+    }
+
+    private PluginEffectApplierRegistry() {
+    }
+
+    public static void register(final PluginEffectApplier<? extends PluginEffect> applier) {
+        APPLIERS.add(applier);
+    }
+
+    public static void apply(final PluginEffect effect) {
+        for (final PluginEffectApplier<? extends PluginEffect> applier : APPLIERS) {
+            if (applier.supports(effect.getClass())) {
+                apply(applier, effect);
+                return;
+            }
+        }
+        throw new IllegalArgumentException("No FuckTick effect applier registered for " + effect.getClass().getName());
+    }
+
+    @SuppressWarnings({"unchecked", "rawtypes"})
+    private static void apply(final PluginEffectApplier applier, final PluginEffect effect) {
+        applier.apply(effect);
+    }
+}
