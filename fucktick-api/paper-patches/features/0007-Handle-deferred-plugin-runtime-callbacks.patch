diff --git a/src/main/java/io/papermc/paper/fucktick/plugin/PluginRuntimeRejectedException.java b/src/main/java/io/papermc/paper/fucktick/plugin/PluginRuntimeRejectedException.java
new file mode 100644
index 0000000000000000000000000000000000000000..30e760561e4c934a0cc8c1e700f0f1347a96a470
--- /dev/null
+++ b/src/main/java/io/papermc/paper/fucktick/plugin/PluginRuntimeRejectedException.java
@@ -0,0 +1,36 @@
+package io.papermc.paper.fucktick.plugin;
+
+import java.util.Objects;
+
+public final class PluginRuntimeRejectedException extends IllegalStateException {
+
+    private final String pluginName;
+    private final String label;
+    private final PluginRuntimeState state;
+
+    public PluginRuntimeRejectedException(final String pluginName, final String label, final PluginRuntimeState state) {
+        super("Plugin " + pluginName + " is not accepting callbacks in state " + state);
+        this.pluginName = Objects.requireNonNull(pluginName, "pluginName");
+        this.label = Objects.requireNonNull(label, "label");
+        this.state = Objects.requireNonNull(state, "state");
+    }
+
+    public String pluginName() {
+        return this.pluginName;
+    }
+
+    public String label() {
+        return this.label;
+    }
+
+    public PluginRuntimeState state() {
+        return this.state;
+    }
+
+    public boolean isShutdownState() {
+        return switch (this.state) {
+            case DRAINING, DISABLING, DISABLED, TERMINATED -> true;
+            default -> false;
+        };
+    }
+}
