     private void cancelQueuedCallbacks(final String reason) {
         final List<PluginTask<?>> drained = new ArrayList<>();
         this.callbackQueue.drainTo(drained);
+        this.controlQueue.drainTo(drained);
         final IllegalStateException exception = new IllegalStateException(reason);
         for (final PluginTask<?> task : drained) {
             task.future.completeExceptionally(exception);
         }
     }
 
+    // FuckTick Start - heartbeat и восстановление потока плагина
+    private WatchCatTargetSnapshot watchCatSnapshot() {
+        final PluginRuntimeSnapshot snapshot = this.snapshot();
+        return new WatchCatTargetSnapshot(
+            this.watchCatTargetId,
+            this.plugin.getName(),
+            WatchCatTargetKind.PLUGIN_RUNTIME,
+            snapshot.threadName(),
+            snapshot.threadId(),
+            this.thread != null && this.thread.isAlive(),
+            snapshot.state().name(),
+            Map.of(
+                "callbacks", Integer.toString(snapshot.queuedTasks()),
+                "lifecycle", Integer.toString(snapshot.lifecycleQueuedTasks()),
+                "control", Integer.toString(this.controlQueue.size()),
+                "runningTask", snapshot.runningTask()
+            )
+        );
+    }
+
+    private CompletableFuture<String> heartbeat(final String payload) {
+        if (Thread.currentThread() == this.thread) {
+            return CompletableFuture.completedFuture(payload);
+        }
+        final CompletableFuture<String> future = new CompletableFuture<>();
+        this.controlQueue.offer(new PluginTask<>("watchcat:heartbeat", false, () -> payload, future));
+        return future;
+    }
+
+    private WatchCatRecoveryResult recoverFromWatchCat(final String reason) {
+        this.cancelQueuedCallbacks("WatchCat recovery: " + reason);
+        final Thread currentThread = this.thread;
+        if (currentThread == null || !currentThread.isAlive()) {
+            return this.restartAfterStoppedThread(currentThread, "Plugin thread was already stopped");
+        }
+        currentThread.interrupt();
+        final WatchCatPingResult ping = WatchCat.instance().ping(this.watchCatTargetId, WatchCatSettings.recoveryWaitMs());
+        if (ping.ok()) {
+            return WatchCatRecoveryResult.interrupted("Plugin thread answered after interrupt");
+        }
+        try {
+            currentThread.join(WatchCatSettings.recoveryWaitMs());
+        } catch (final InterruptedException interruptedException) {
+            Thread.currentThread().interrupt();
+            return WatchCatRecoveryResult.escalate("Interrupted while waiting for plugin thread recovery");
+        }
+        if (currentThread.isAlive()) {
+            return WatchCatRecoveryResult.escalate("Plugin thread did not stop after interrupt. reason=" + reason);
+        }
+        this.cancelQueuedCallbacks("WatchCat restart after stopped plugin thread");
+        return this.restartAfterStoppedThread(currentThread, "Plugin thread restarted after WatchCat recovery");
+    }
+
+    private synchronized WatchCatRecoveryResult restartAfterStoppedThread(final Thread oldThread, final String message) {
+        if (oldThread != null && this.thread == oldThread) {
+            this.thread = null;
+        }
+        final PluginRuntimeState current = this.state.get();
+        if (current == PluginRuntimeState.ENABLING || current == PluginRuntimeState.ENABLED) {
+            this.stopRequested = false;
+            this.start();
+            return WatchCatRecoveryResult.restarted(message);
+        }
+        return WatchCatRecoveryResult.interrupted(message + ". state=" + current);
+    }
+    // FuckTick End
+
     private void fail(final String label, final Throwable throwable) {
         this.failure = throwable;
         this.state.set(PluginRuntimeState.FAILED);
