+    // FuckTick Start - heartbeat и восстановление управляющего потока
+    private CompletableFuture<String> managementHeartbeat(final String payload) {
+        final CompletableFuture<String> heartbeat = new CompletableFuture<>();
+        try {
+            this.managementExecutor.execute(() -> heartbeat.complete(payload));
+        } catch (final RejectedExecutionException rejectedExecutionException) {
+            heartbeat.completeExceptionally(rejectedExecutionException);
+        }
+        return heartbeat;
+    }
+
+    private WatchCatRecoveryResult recoverManagementThread(final String reason) {
+        final Thread thread = this.managementThread.get();
+        if (thread == null || !thread.isAlive()) {
+            return WatchCatRecoveryResult.none("Plugin management thread is not alive");
+        }
+        thread.interrupt();
+        final WatchCatPingResult ping = WatchCat.instance().ping("plugin-management:PluginFUCKLOADER", WatchCatSettings.recoveryWaitMs());
+        if (ping.ok()) {
+            return WatchCatRecoveryResult.interrupted("Plugin management thread answered after interrupt");
+        }
+        return WatchCatRecoveryResult.escalate("Plugin management thread did not answer after interrupt. reason=" + reason);
+    }
+    // FuckTick End
